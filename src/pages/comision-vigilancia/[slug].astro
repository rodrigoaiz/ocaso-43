---
import Layout from '../../layouts/Layout.astro';
import { getCollection, getEntry } from 'astro:content';
import VoteButtons from '../../components/VoteButtons.astro';
import VoteResults from '../../components/VoteResults.astro';
import { createSupabaseClient } from '../../lib/supabase';
import { autoSyncProyectosSilent } from '../../lib/auto-sync-proyectos';

export const prerender = false;

const comisionUser = Astro.locals.comisionUser;

if (!comisionUser) {
  return Astro.redirect('/comision-vigilancia/login');
}

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/comision-vigilancia');
}

// Cargar proyecto desde Content Collection
const proyecto = await getEntry('proyectos-votacion', slug);

if (!proyecto) {
  return Astro.redirect('/comision-vigilancia?error=proyecto_no_encontrado');
}

// Auto-sincronizar proyectos antes de consultar BD
await autoSyncProyectosSilent();

const supabase = createSupabaseClient();

// Obtener proyecto de BD
const { data: proyectoBD } = await supabase
  .from('proyectos_votacion')
  .select('*')
  .eq('slug', slug)
  .single();

if (!proyectoBD) {
  return Astro.redirect('/comision-vigilancia?error=proyecto_no_sincronizado');
}

// Obtener opciones de producto si es votación de selección
let opciones: any[] | undefined = undefined;
if (proyectoBD.tipo_votacion === 'seleccion') {
  const { data: opcionesData } = await supabase
    .from('opciones_producto')
    .select('*')
    .eq('proyecto_id', proyectoBD.id)
    .order('orden', { ascending: true });
  
  opciones = opcionesData || [];
}

// Obtener votos (con opciones de producto si es selección)
const { data: votos, count: votosCount } = await supabase
  .from('votos')
  .select(`
    *,
    usuario:comision_usuarios(username),
    opcion:opciones_producto(*)
  `, { count: 'exact' })
  .eq('proyecto_id', proyectoBD.id);

// Verificar si el usuario actual ya votó
const votoUsuario = votos?.find(v => v.usuario_id === comisionUser.id);
const hasUserVoted = !!votoUsuario;

// Votación completa si hay 2 o más votos
const votacionCompleta = (votosCount || 0) >= 2;

// Verificar si la votación está abierta (desde MDX)
const votacionAbierta = proyecto.data.votacion_abierta ?? true;

// Renderizar contenido MDX
const { Content } = await proyecto.render();
---

<Layout title={`${proyecto.data.titulo} - Comisión de Vigilancia`}>
  <div class="container mx-auto px-4 max-w-4xl">
    <!-- Breadcrumbs -->
    <nav class="mb-6">
      <a
        href="/comision-vigilancia"
        class="text-slate-600 hover:text-orange-600 font-semibold transition-colors inline-flex items-center gap-2"
      >
        ← Volver a proyectos
      </a>
    </nav>

    <!-- Header del Proyecto -->
    <header class="mb-8">
      <div class="flex flex-wrap gap-3 mb-4">
        {proyecto.data.categoria && (
          <span class="inline-block bg-orange-100 text-orange-700 px-4 py-2 rounded-full text-sm font-bold uppercase tracking-wide">
            {proyecto.data.categoria}
          </span>
        )}
        
        {proyecto.data.mes && proyecto.data.anio && (
          <span class="inline-block bg-slate-100 text-slate-700 px-4 py-2 rounded-full text-sm font-bold">
            📅 {proyecto.data.mes.toString().padStart(2, '0')}/{proyecto.data.anio}
          </span>
        )}
        
        {proyecto.data.presupuesto_estimado && (
          <span class="inline-block bg-emerald-100 text-emerald-700 px-4 py-2 rounded-full text-sm font-bold">
            💰 ${new Intl.NumberFormat('es-MX').format(proyecto.data.presupuesto_estimado)} MXN
          </span>
        )}
        
        {proyecto.data.proveedor && (
          <span class="inline-block bg-blue-100 text-blue-700 px-4 py-2 rounded-full text-sm font-bold">
            🏢 {proyecto.data.proveedor}
          </span>
        )}
      </div>

      <h1 class="font-black text-4xl text-slate-900 mb-4">
        {proyecto.data.titulo}
      </h1>
      
      {proyecto.data.descripcion_corta && (
        <p class="text-lg text-slate-600 leading-relaxed">
          {proyecto.data.descripcion_corta}
        </p>
      )}
      
      <!-- Botón para saltar a votación -->
      <div class="mt-6">
        <a
          href="#seccion-votacion"
          class="inline-flex items-center gap-2 text-sm font-bold text-slate-500 hover:text-orange-500 transition-colors group"
        >
          <svg class="w-5 h-5 transition-transform group-hover:translate-y-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
          </svg>
          Saltar a votación
        </a>
      </div>
    </header>

    <!-- Contenido del Proyecto (MDX) - PRIMERO -->
    <div id="detalles-proyecto" class="mb-32 scroll-mt-20">
      <h2 class="font-black text-2xl text-slate-900 mb-6 flex items-center gap-3">
        <span class="text-3xl">📄</span>
        <span>Detalles del Proyecto</span>
      </h2>
      
      <!-- Contenedor con efecto de colapso -->
      <div id="content-container" class="relative">
        <!-- Máscara de degradado cuando está colapsado -->
        <div id="fade-overlay" class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-slate-50 to-transparent pointer-events-none rounded-b-[2rem] z-10"></div>
        
        <!-- Contenido con altura máxima inicial -->
        <article id="project-content" class="prose prose-orange prose-lg max-w-none rounded-[2rem] bg-white/80 backdrop-blur-sm p-8 pb-16 shadow-xl border border-slate-100 overflow-hidden transition-all duration-500 max-h-[500px]">
          <Content />
        </article>
      </div>
      
      <!-- Botón Ver más -->
      <div class="text-center mt-6">
        <button
          id="toggle-content-btn"
          class="inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-orange-500 to-pink-500 text-white font-black rounded-full shadow-lg hover:shadow-xl transition-all hover:scale-105 text-sm uppercase tracking-wide"
        >
          <span id="btn-text">Ver detalles completos</span>
          <svg id="btn-icon" class="w-5 h-5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
          </svg>
        </button>
      </div>
    </div>
    
    <script>
      // Script para expandir/colapsar contenido
      const toggleBtn = document.getElementById('toggle-content-btn');
      const content = document.getElementById('project-content');
      const fadeOverlay = document.getElementById('fade-overlay');
      const btnText = document.getElementById('btn-text');
      const btnIcon = document.getElementById('btn-icon');
      
      let isExpanded = false;
      
      toggleBtn?.addEventListener('click', () => {
        isExpanded = !isExpanded;
        
        if (isExpanded) {
          // Expandir
          content?.classList.remove('max-h-[500px]');
          content?.classList.add('max-h-[9999px]');
          fadeOverlay?.classList.add('opacity-0');
          btnText!.textContent = 'Ver menos';
          btnIcon?.classList.add('rotate-180');
        } else {
          // Colapsar
          content?.classList.remove('max-h-[9999px]');
          content?.classList.add('max-h-[500px]');
          fadeOverlay?.classList.remove('opacity-0');
          btnText!.textContent = 'Ver detalles completos';
          btnIcon?.classList.remove('rotate-180');
          
          // Scroll suave hacia arriba del contenido
          document.getElementById('detalles-proyecto')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    </script>

    <!-- Separador visual -->
    <div class="mb-8 flex items-center gap-4">
      <div class="flex-1 h-px bg-gradient-to-r from-transparent via-slate-300 to-transparent"></div>
      <span class="text-slate-400 font-bold text-sm uppercase tracking-wider">Sección de Votación</span>
      <div class="flex-1 h-px bg-gradient-to-r from-transparent via-slate-300 to-transparent"></div>
    </div>

    <!-- Sección de Votación - DESPUÉS -->
    <div id="seccion-votacion" class="space-y-6 mb-10 scroll-mt-20">
      {!votacionAbierta ? (
        <!-- Votación cerrada -->
        <div class="rounded-2xl bg-white border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-6 pt-6 pb-5 border-b border-slate-100">
            <p class="text-[10px] font-black uppercase tracking-[0.4em] text-slate-400 mb-1">Estado</p>
            <h3 class="text-xl font-black text-slate-900 tracking-tight">Votación cerrada</h3>
          </div>
          <div class="p-6 flex items-start gap-3">
            <div class="w-9 h-9 rounded-xl bg-slate-100 border border-slate-200 flex items-center justify-center shrink-0">
              <svg class="w-4.5 h-4.5 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/>
              </svg>
            </div>
            <p class="text-sm font-bold text-slate-600 leading-relaxed">Ya no es posible emitir o modificar votos en este proyecto.</p>
          </div>
        </div>
      ) : hasUserVoted ? (
        <!-- Usuario ya votó -->
        <div class="rounded-2xl bg-white border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-6 pt-6 pb-5 border-b border-slate-100">
            <p class="text-[10px] font-black uppercase tracking-[0.4em] text-slate-400 mb-1">Tu voto</p>
            <h3 class="text-xl font-black text-slate-900 tracking-tight">Ya emitiste tu voto</h3>
          </div>
          <div class="p-6 space-y-4">
            {proyectoBD.tipo_votacion === 'binaria' ? (
              <div class={`inline-flex items-center gap-2 px-4 py-3 rounded-xl border font-black text-sm ${votoUsuario.voto === 'a_favor' ? 'bg-green-50 border-green-200 text-green-700' : 'bg-red-50 border-red-200 text-red-700'}`}>
                {votoUsuario.voto === 'a_favor' ? (
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6.633 10.5c.806 0 1.533-.446 2.031-1.08a9.041 9.041 0 012.861-2.4c.723-.384 1.35-.956 1.653-1.715a4.498 4.498 0 00.322-1.672V3a.75.75 0 01.75-.75A2.25 2.25 0 0116.5 4.5c0 1.152-.26 2.243-.723 3.218-.266.558.107 1.282.725 1.282h3.126c1.026 0 1.945.694 2.054 1.715.045.422.068.85.068 1.285a11.95 11.95 0 01-2.649 7.521c-.388.482-.987.729-1.605.729H13.48c-.483 0-.964-.078-1.423-.23l-3.114-1.04a4.501 4.501 0 00-1.423-.23H5.904M14.25 9h2.25M5.904 18.75c.083.205.173.405.27.602.197.4-.078.898-.523.898h-.908c-.889 0-1.713-.518-1.972-1.368a12 12 0 01-.521-3.507c0-1.553.295-3.036.831-4.398C3.387 10.203 4.167 9.75 5 9.75h1.053c.472 0 .745.556.5.96a8.958 8.958 0 00-1.302 4.665c0 1.194.232 2.333.654 3.375z"/>
                  </svg>
                ) : (
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 15h2.25m8.024-9.75c.011.05.028.1.052.148.591 1.2.924 2.55.924 3.977a8.96 8.96 0 01-.999 4.125m.023-8.25c-.076-.365.183-.75.575-.75h.908c.889 0 1.713.518 1.972 1.368.339 1.11.521 2.287.521 3.507 0 1.553-.295 3.036-.831 4.398C20.613 14.547 19.833 15 19 15h-1.053c-.472 0-.745-.556-.5-.96a8.95 8.95 0 00.303-.54m.023-8.25H16.48a4.5 4.5 0 01-1.423-.23l-3.114-1.04a4.5 4.5 0 00-1.423-.23H6.504c-.618 0-1.217.247-1.605.729A11.95 11.95 0 002.25 12c0 .434.023.863.068 1.285C2.427 14.306 3.346 15 4.372 15h3.126c.618 0 .991.724.725 1.282A7.471 7.471 0 007.5 19.5a2.25 2.25 0 002.25 2.25.75.75 0 00.75-.75v-.633c0-.573.11-1.14.322-1.672.304-.76.93-1.33 1.653-1.715a9.04 9.04 0 002.86-2.4c.498-.634 1.226-1.08 2.032-1.08h.384"/>
                  </svg>
                )}
                {votoUsuario.voto === 'a_favor' ? 'A favor' : 'En contra'}
              </div>
            ) : (
              <div class="px-4 py-3 rounded-xl bg-slate-50 border border-slate-200">
                <p class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-1">Opción seleccionada</p>
                <p class="font-black text-base text-slate-900">
                  {votoUsuario.opcion_producto_id && opciones
                    ? opciones.find(o => o.id === votoUsuario.opcion_producto_id)?.nombre || 'Opción seleccionada'
                    : 'Opción seleccionada'}
                </p>
              </div>
            )}
            <div class="flex items-center gap-2 text-xs font-bold text-slate-400">
              <svg class="w-3.5 h-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/>
              </svg>
              Los votos son definitivos y no pueden cambiarse
            </div>
          </div>
        </div>
      ) : (
        <!-- Usuario no ha votado -->
        <VoteButtons slug={slug} userRol={comisionUser.rol} tipoVotacion={proyectoBD.tipo_votacion} opciones={opciones} />
      )}

      <!-- Resultados (solo si votación completa) -->
      {votacionCompleta && votos ? (
        <VoteResults votos={votos} votosCount={votosCount || 0} tipoVotacion={proyectoBD.tipo_votacion} opciones={opciones || []} />
      ) : (
        <!-- Votación en proceso -->
        <div class="rounded-2xl bg-white border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-6 pt-6 pb-5 border-b border-slate-100">
            <p class="text-[10px] font-black uppercase tracking-[0.4em] text-slate-400 mb-1">Progreso</p>
            <h3 class="text-xl font-black text-slate-900 tracking-tight">Votación en proceso</h3>
          </div>
          <div class="p-6 space-y-4">
            <div class="flex items-end gap-2">
              <span class="text-5xl font-black text-slate-900 leading-none">{votosCount || 0}</span>
              <span class="text-xl font-black text-slate-300 leading-none mb-1">/ 3</span>
              <span class="text-xs font-black uppercase tracking-widest text-slate-400 mb-1.5 ml-1">votos</span>
            </div>
            <div class="w-full h-2 bg-slate-100 rounded-full overflow-hidden">
              <div
                class="h-full bg-slate-900 rounded-full transition-all duration-500"
                style={`width: ${Math.round(((votosCount || 0) / 3) * 100)}%`}
              ></div>
            </div>
            <p class="text-xs font-bold text-slate-400">
              Los resultados serán visibles cuando al menos 2 miembros voten
            </p>
          </div>
        </div>
      )}
    </div>
  </div>
</Layout>
