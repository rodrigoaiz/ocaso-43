---
import Layout from '../../layouts/Layout.astro';
import { getCollection, getEntry } from 'astro:content';
import VoteButtons from '../../components/VoteButtons.astro';
import VoteResults from '../../components/VoteResults.astro';
import { createSupabaseClient } from '../../lib/supabase';
import { autoSyncProyectosSilent } from '../../lib/auto-sync-proyectos';

export const prerender = false;

const comisionUser = Astro.locals.comisionUser;

if (!comisionUser) {
  return Astro.redirect('/comision-vigilancia/login');
}

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/comision-vigilancia');
}

// Cargar proyecto desde Content Collection
const proyecto = await getEntry('proyectos-votacion', slug);

if (!proyecto) {
  return Astro.redirect('/comision-vigilancia?error=proyecto_no_encontrado');
}

// Auto-sincronizar proyectos antes de consultar BD
await autoSyncProyectosSilent();

const supabase = createSupabaseClient();

// Obtener proyecto de BD
const { data: proyectoBD } = await supabase
  .from('proyectos_votacion')
  .select('*')
  .eq('slug', slug)
  .single();

if (!proyectoBD) {
  return Astro.redirect('/comision-vigilancia?error=proyecto_no_sincronizado');
}

// Obtener votos
const { data: votos, count: votosCount } = await supabase
  .from('votos')
  .select(`
    *,
    usuario:comision_usuarios(username)
  `, { count: 'exact' })
  .eq('proyecto_id', proyectoBD.id);

// Verificar si el usuario actual ya votó
const votoUsuario = votos?.find(v => v.usuario_id === comisionUser.id);
const hasUserVoted = !!votoUsuario;

// Votación completa si hay 2 o más votos
const votacionCompleta = (votosCount || 0) >= 2;

// Verificar si la votación está abierta (desde MDX)
const votacionAbierta = proyecto.data.votacion_abierta ?? true;

// Renderizar contenido MDX
const { Content } = await proyecto.render();
---

<Layout title={`${proyecto.data.titulo} - Comisión de Vigilancia`}>
  <div class="container mx-auto px-4 max-w-4xl">
    <!-- Breadcrumbs -->
    <nav class="mb-6">
      <a
        href="/comision-vigilancia"
        class="text-slate-600 hover:text-orange-600 font-semibold transition-colors inline-flex items-center gap-2"
      >
        ← Volver a proyectos
      </a>
    </nav>

    <!-- Header del Proyecto -->
    <header class="mb-8">
      <div class="flex flex-wrap gap-3 mb-4">
        {proyecto.data.categoria && (
          <span class="inline-block bg-orange-100 text-orange-700 px-4 py-2 rounded-full text-sm font-bold uppercase tracking-wide">
            {proyecto.data.categoria}
          </span>
        )}
        
        {proyecto.data.mes && proyecto.data.anio && (
          <span class="inline-block bg-slate-100 text-slate-700 px-4 py-2 rounded-full text-sm font-bold">
            📅 {proyecto.data.mes.toString().padStart(2, '0')}/{proyecto.data.anio}
          </span>
        )}
        
        {proyecto.data.presupuesto_estimado && (
          <span class="inline-block bg-emerald-100 text-emerald-700 px-4 py-2 rounded-full text-sm font-bold">
            💰 ${new Intl.NumberFormat('es-MX').format(proyecto.data.presupuesto_estimado)} MXN
          </span>
        )}
        
        {proyecto.data.proveedor && (
          <span class="inline-block bg-blue-100 text-blue-700 px-4 py-2 rounded-full text-sm font-bold">
            🏢 {proyecto.data.proveedor}
          </span>
        )}
      </div>

      <h1 class="font-black text-4xl text-slate-900 mb-4">
        {proyecto.data.titulo}
      </h1>
      
      {proyecto.data.descripcion_corta && (
        <p class="text-lg text-slate-600 leading-relaxed">
          {proyecto.data.descripcion_corta}
        </p>
      )}
      
      <!-- Botón para saltar a detalles -->
      <div class="mt-6">
        <a
          href="#detalles-proyecto"
          class="inline-flex items-center gap-2 text-sm font-bold text-slate-500 hover:text-orange-500 transition-colors group"
        >
          <svg class="w-5 h-5 transition-transform group-hover:translate-y-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
          </svg>
          Saltar a detalles del proyecto
        </a>
      </div>
    </header>

    <!-- Sección de Votación (PRIMERO) -->
    <div class="space-y-6 mb-10">
      {!votacionAbierta ? (
        <!-- Votación cerrada -->
        <div class="bg-gradient-to-br from-slate-100 to-slate-200 rounded-[2rem] p-6 text-center border-2 border-slate-300 shadow-lg">
          <div class="inline-block bg-white/60 backdrop-blur-sm rounded-[1.5rem] px-6 py-4 mb-3">
            <p class="text-slate-700 text-base mb-2">🔒 Esta votación ha sido cerrada</p>
            <p class="font-black text-2xl text-slate-600">
              Votación cerrada
            </p>
          </div>
          <div class="bg-slate-50 border-2 border-slate-300 rounded-xl p-3 inline-block">
            <p class="text-sm text-slate-700 font-bold">
              Ya no es posible emitir o modificar votos en este proyecto
            </p>
          </div>
        </div>
      ) : hasUserVoted ? (
        <!-- Usuario ya votó -->
        <div class="bg-gradient-to-br from-slate-50 to-slate-100 rounded-[2rem] p-6 text-center border-2 border-slate-200 shadow-lg">
          <div class="inline-block bg-white/60 backdrop-blur-sm rounded-[1.5rem] px-6 py-4 mb-3">
            <p class="text-slate-600 text-base mb-2">Ya emitiste tu voto:</p>
            <p class="font-black text-3xl mb-1">
              {votoUsuario.voto === 'a_favor' ? '👍 A FAVOR' : '👎 EN CONTRA'}
            </p>
          </div>
          <div class="bg-amber-50 border-2 border-amber-200 rounded-xl p-3 inline-block">
            <p class="text-xs text-amber-800 font-bold flex items-center gap-2">
              <span>🔒</span>
              <span>Los votos son definitivos y no pueden cambiarse</span>
            </p>
          </div>
        </div>
      ) : (
        <!-- Usuario no ha votado -->
        <VoteButtons slug={slug} userRol={comisionUser.rol} />
      )}

      <!-- Resultados (solo si votación completa) -->
      {votacionCompleta && votos ? (
        <VoteResults votos={votos} votosCount={votosCount || 0} />
      ) : (
        <!-- Votación en proceso -->
        <div class="bg-gradient-to-br from-amber-50 to-orange-50 rounded-[2rem] p-5 border-2 border-amber-200 text-center shadow-lg">
          <p class="text-amber-900 font-black text-xl mb-3">
            ⏳ Votación en proceso
          </p>
          <div class="flex items-center justify-center gap-3 mb-2">
            <div class="text-4xl font-black text-amber-600">
              {votosCount || 0}
            </div>
            <div class="text-2xl text-amber-400">/</div>
            <div class="text-3xl font-bold text-amber-500">3</div>
          </div>
          <p class="text-amber-700 font-semibold text-sm mb-3">
            votos emitidos
          </p>
          <p class="text-amber-600 text-xs font-medium">
            📊 Los resultados serán visibles cuando al menos 2 miembros voten
          </p>
        </div>
      )}
    </div>

    <!-- Contenido del Proyecto (MDX) - DESPUÉS -->
    <div id="detalles-proyecto" class="mb-8 scroll-mt-20">
      <h2 class="font-black text-2xl text-slate-900 mb-6 flex items-center gap-3">
        <span class="text-3xl">📄</span>
        <span>Detalles del Proyecto</span>
      </h2>
      <article class="prose prose-orange prose-lg max-w-none rounded-[2rem] bg-white/80 backdrop-blur-sm p-8 shadow-xl border border-slate-100">
        <Content />
      </article>
    </div>
  </div>
</Layout>
