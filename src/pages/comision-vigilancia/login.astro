---
import Layout from '../../layouts/Layout.astro';
import { loginComisionUser, createComisionSession } from '../../lib/auth-comision';

let error = '';
let loading = false;

if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const username = formData.get('username')?.toString();
    const password = formData.get('password')?.toString();

    if (!username || !password) {
      error = 'Por favor ingresa usuario y contraseña';
    } else {
      const result = await loginComisionUser(username, password);

      if (result.success && result.user) {
        createComisionSession(Astro.cookies, result.user);
        return Astro.redirect('/comision-vigilancia');
      } else {
        error = result.error || 'Error al iniciar sesión';
      }
    }
  } catch (e) {
    error = 'Error al procesar el login';
  }
}

const reason = Astro.url.searchParams.get('reason');
if (reason === 'no_session' && !error) {
  error = 'Sesión expirada. Por favor inicia sesión nuevamente';
}
---

<Layout title="Login - Comisión de Vigilancia">
  <div class="container mx-auto px-4 py-12 max-w-md">
    <div class="w-full">
      <!-- Header -->
      <div class="text-center mb-8">
        <h1 class="font-black text-4xl bg-gradient-to-r from-orange-500 via-pink-500 to-violet-600 bg-clip-text text-transparent mb-4">
          Comisión de Vigilancia
        </h1>
        <p class="text-slate-600">
          Sistema de votación de proyectos
        </p>
      </div>

      <!-- Card de Login -->
      <div class="rounded-[2rem] bg-white/80 backdrop-blur-sm p-8 shadow-2xl shadow-orange-500/10 border border-slate-100">
        <h2 class="font-black text-2xl text-slate-800 mb-6">
          Iniciar Sesión
        </h2>

        {error && (
          <div class="mb-6 p-4 bg-red-100 border-2 border-red-300 rounded-xl text-red-800 text-sm">
            ⚠️ {error}
          </div>
        )}

        <form method="POST" class="space-y-6">
          <div>
            <label for="username" class="block text-sm font-bold text-slate-700 mb-2">
              Usuario
            </label>
            <input
              type="text"
              id="username"
              name="username"
              required
              autocomplete="username"
              class="w-full px-4 py-3 rounded-xl border-2 border-slate-200 focus:border-orange-400 focus:outline-none focus:ring-2 focus:ring-orange-200 transition-all"
              placeholder="Ingresa tu usuario"
            />
          </div>

          <div>
            <label for="password" class="block text-sm font-bold text-slate-700 mb-2">
              Contraseña
            </label>
            <input
              type="password"
              id="password"
              name="password"
              required
              autocomplete="current-password"
              class="w-full px-4 py-3 rounded-xl border-2 border-slate-200 focus:border-orange-400 focus:outline-none focus:ring-2 focus:ring-orange-200 transition-all"
              placeholder="••••••••"
            />
          </div>

          <button
            type="submit"
            class="w-full bg-gradient-to-r from-orange-500 to-pink-500 hover:from-orange-600 hover:to-pink-600 text-white font-black py-4 px-6 rounded-[1rem] transition-all shadow-lg hover:shadow-xl hover:scale-105 active:scale-95"
          >
            Iniciar Sesión
          </button>
        </form>

        <div class="mt-6 pt-6 border-t border-slate-200">
          <p class="text-xs text-slate-500 text-center">
            🔒 Acceso exclusivo para miembros de la Comisión de Vigilancia
          </p>
        </div>
      </div>

      <!-- Link al sitio principal -->
      <div class="text-center mt-6">
        <a
          href="/"
          class="text-slate-600 hover:text-orange-600 text-sm font-semibold transition-colors"
        >
          ← Volver al sitio principal
        </a>
      </div>
    </div>
  </div>
</Layout>
