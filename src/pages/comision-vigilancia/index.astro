---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import VotingCard from '../../components/VotingCard.astro';
import { createSupabaseClient } from '../../lib/supabase';
import { autoSyncProyectosSilent } from '../../lib/auto-sync-proyectos';

const comisionUser = Astro.locals.comisionUser;

if (!comisionUser) {
  return Astro.redirect('/comision-vigilancia/login');
}

// Auto-sincronizar proyectos MDX a Supabase (silenciosamente)
await autoSyncProyectosSilent();

// Cargar proyectos desde Content Collection
const proyectos = await getCollection('proyectos-votacion');

// Obtener información de votos desde Supabase
const supabase = createSupabaseClient();

// Obtener todos los proyectos desde BD para verificar estado
const { data: proyectosBD } = await supabase
  .from('proyectos_votacion')
  .select('*');

// Para cada proyecto, obtener votos
const proyectosConEstado = await Promise.all(
  proyectos.map(async (proyecto) => {
    const proyectoBD = proyectosBD?.find(p => p.slug === proyecto.slug);
    
    if (!proyectoBD) {
      return {
        proyecto,
        votosCount: 0,
        votacionCompleta: false,
        hasUserVoted: false,
      };
    }

    // Contar votos
    const { data: votos, count } = await supabase
      .from('votos')
      .select('*', { count: 'exact' })
      .eq('proyecto_id', proyectoBD.id);

    // Verificar si el usuario actual ya votó
    const hasUserVoted = votos?.some(v => v.usuario_id === comisionUser.id) || false;

    return {
      proyecto,
      votosCount: count || 0,
      votacionCompleta: proyectoBD.votacion_completa,
      hasUserVoted,
    };
  })
);

// Separar proyectos abiertos y cerrados
const proyectosAbiertos = proyectosConEstado
  .filter(p => p.proyecto.data.votacion_abierta !== false)
  .sort((a, b) => {
    // Primero los que el usuario no ha votado
    if (!a.hasUserVoted && b.hasUserVoted) return -1;
    if (a.hasUserVoted && !b.hasUserVoted) return 1;
    // Luego por fecha (más recientes primero)
    const dateA = new Date(a.proyecto.data.fecha);
    const dateB = new Date(b.proyecto.data.fecha);
    return dateB.getTime() - dateA.getTime();
  });

const proyectosCerrados = proyectosConEstado
  .filter(p => p.proyecto.data.votacion_abierta === false)
  .sort((a, b) => {
    // Por fecha (más recientes primero)
    const dateA = new Date(a.proyecto.data.fecha);
    const dateB = new Date(b.proyecto.data.fecha);
    return dateB.getTime() - dateA.getTime();
  });
---

<Layout title="Dashboard - Comisión de Vigilancia">
  <div class="container mx-auto px-4 max-w-5xl">
    <!-- Header -->
    <div class="mb-12">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
        <div>
          <h1 class="font-black text-4xl bg-gradient-to-r from-orange-500 via-pink-500 to-violet-600 bg-clip-text text-transparent mb-2">
            Comisión de Vigilancia
          </h1>
          <p class="text-slate-600">
            Bienvenido, <span class="font-bold capitalize">{comisionUser.username}</span>
          </p>
        </div>
        
        <div class="flex gap-3">
          <a
            href="/comision-vigilancia/tickets"
            class="inline-flex items-center gap-2 bg-orange-100 hover:bg-orange-200 text-orange-700 font-bold py-3 px-6 rounded-[1rem] transition-all"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.625 9.75a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375m-13.5 3.01c0 1.6 1.123 2.994 2.707 3.227 1.087.16 2.185.283 3.293.369V21l4.184-4.183a1.14 1.14 0 0 1 .778-.332 48.294 48.294 0 0 0 5.83-.498c1.585-.233 2.708-1.626 2.708-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0 0 12 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018Z"/>
            </svg>
            Solicitudes
          </a>
          <a
            href="/comision-vigilancia/perfil"
            class="inline-flex items-center gap-2 bg-blue-100 hover:bg-blue-200 text-blue-700 font-bold py-3 px-6 rounded-[1rem] transition-all"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
            </svg>
            Mi Perfil
          </a>
          <a
            href="/api/logout-comision"
            class="inline-flex items-center gap-2 bg-slate-200 hover:bg-slate-300 text-slate-700 font-bold py-3 px-6 rounded-[1rem] transition-all"
          >
            Cerrar Sesión
          </a>
        </div>
      </div>

      <div class="bg-gradient-to-r from-orange-100 to-pink-100 rounded-[2rem] p-6 border-2 border-orange-200">
        <h2 class="font-black text-lg text-slate-800 mb-2">
          📋 Proyectos en Votación
        </h2>
        <p class="text-slate-600 text-sm">
          Revisa y vota en los proyectos propuestos. Los resultados son visibles cuando al menos 2 miembros han votado (quórum).
        </p>
      </div>
    </div>

    <!-- Votaciones Abiertas -->
    {proyectosAbiertos.length === 0 && proyectosCerrados.length === 0 ? (
      <div class="text-center py-20">
        <p class="text-slate-500 text-lg">
          No hay proyectos en votación actualmente
        </p>
      </div>
    ) : (
      <>
        {proyectosAbiertos.length > 0 && (
          <div class="mb-12">
            <h2 class="font-black text-2xl text-slate-800 mb-6">
              📊 Votaciones Activas
            </h2>
            <div class="grid gap-6">
              {proyectosAbiertos.map(({ proyecto, votosCount, votacionCompleta, hasUserVoted }) => (
                <VotingCard
                  proyecto={proyecto}
                  votosCount={votosCount}
                  votacionCompleta={votacionCompleta}
                  hasUserVoted={hasUserVoted}
                />
              ))}
            </div>
          </div>
        )}

        {proyectosCerrados.length > 0 && (
          <div>
            <h2 class="font-black text-2xl text-slate-800 mb-2">
              📚 Historial de Votaciones
            </h2>
            <p class="text-slate-600 mb-6 text-sm">
              Votaciones cerradas y archivadas
            </p>
            <div class="grid gap-6 opacity-75">
              {proyectosCerrados.map(({ proyecto, votosCount, votacionCompleta, hasUserVoted }) => (
                <VotingCard
                  proyecto={proyecto}
                  votosCount={votosCount}
                  votacionCompleta={votacionCompleta}
                  hasUserVoted={hasUserVoted}
                />
              ))}
            </div>
          </div>
        )}
      </>
    )}
  </div>
</Layout>
