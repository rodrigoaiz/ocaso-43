---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import VotingCard from '../../components/VotingCard.astro';
import { createSupabaseClient } from '../../lib/supabase';
import { autoSyncProyectosSilent } from '../../lib/auto-sync-proyectos';

const comisionUser = Astro.locals.comisionUser;

if (!comisionUser) {
  return Astro.redirect('/comision-vigilancia/login');
}

// Auto-sincronizar proyectos MDX a Supabase (silenciosamente)
await autoSyncProyectosSilent();

// Cargar proyectos desde Content Collection
const proyectos = await getCollection('proyectos-votacion');

// Obtener información de votos desde Supabase
const supabase = createSupabaseClient();

// Obtener todos los proyectos desde BD para verificar estado
const { data: proyectosBD } = await supabase
  .from('proyectos_votacion')
  .select('*');

// Para cada proyecto, obtener votos
const proyectosConEstado = await Promise.all(
  proyectos.map(async (proyecto) => {
    const proyectoBD = proyectosBD?.find(p => p.slug === proyecto.slug);
    
    if (!proyectoBD) {
      return {
        proyecto,
        votosCount: 0,
        votacionCompleta: false,
        hasUserVoted: false,
      };
    }

    // Contar votos
    const { data: votos, count } = await supabase
      .from('votos')
      .select('*', { count: 'exact' })
      .eq('proyecto_id', proyectoBD.id);

    // Verificar si el usuario actual ya votó
    const hasUserVoted = votos?.some(v => v.usuario_id === comisionUser.id) || false;

    return {
      proyecto,
      votosCount: count || 0,
      votacionCompleta: proyectoBD.votacion_completa,
      hasUserVoted,
    };
  })
);

// Ordenar: pendientes primero, luego en proceso, luego completados
const proyectosOrdenados = proyectosConEstado.sort((a, b) => {
  if (!a.hasUserVoted && b.hasUserVoted) return -1;
  if (a.hasUserVoted && !b.hasUserVoted) return 1;
  if (!a.votacionCompleta && b.votacionCompleta) return -1;
  if (a.votacionCompleta && !b.votacionCompleta) return 1;
  return 0;
});
---

<Layout title="Dashboard - Comisión de Vigilancia">
  <div class="container mx-auto px-4 py-12 max-w-5xl">
    <!-- Header -->
    <div class="mb-12">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
        <div>
          <h1 class="font-black text-4xl bg-gradient-to-r from-orange-500 via-pink-500 to-violet-600 bg-clip-text text-transparent mb-2">
            Comisión de Vigilancia
          </h1>
          <p class="text-slate-600">
            Bienvenido, <span class="font-bold capitalize">{comisionUser.username}</span>
          </p>
        </div>
        
        <a
          href="/api/logout-comision"
          class="inline-flex items-center gap-2 bg-slate-200 hover:bg-slate-300 text-slate-700 font-bold py-3 px-6 rounded-[1rem] transition-all"
        >
          Cerrar Sesión
        </a>
      </div>

      <div class="bg-gradient-to-r from-orange-100 to-pink-100 rounded-[2rem] p-6 border-2 border-orange-200">
        <h2 class="font-black text-lg text-slate-800 mb-2">
          📋 Proyectos en Votación
        </h2>
        <p class="text-slate-600 text-sm">
          Revisa y vota en los proyectos propuestos. Los resultados son visibles cuando al menos 2 miembros han votado (quórum).
        </p>
      </div>
    </div>

    <!-- Lista de Proyectos -->
    {proyectosOrdenados.length === 0 ? (
      <div class="text-center py-20">
        <p class="text-slate-500 text-lg">
          No hay proyectos en votación actualmente
        </p>
      </div>
    ) : (
      <div class="grid gap-6">
        {proyectosOrdenados.map(({ proyecto, votosCount, votacionCompleta, hasUserVoted }) => (
          <VotingCard
            proyecto={proyecto}
            votosCount={votosCount}
            votacionCompleta={votacionCompleta}
            hasUserVoted={hasUserVoted}
          />
        ))}
      </div>
    )}
  </div>
</Layout>
