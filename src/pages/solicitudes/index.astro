---
import Layout from '../../layouts/Layout.astro';
import { supabase } from '../../lib/supabase';
import type { Ticket } from '../../lib/supabase';

// Cargar todos los tickets ordenados por fecha
const { data: tickets, error } = await supabase
  .from('tickets')
  .select('*')
  .order('created_at', { ascending: false });

const allTickets: Ticket[] = tickets ?? [];

// Contadores por estado
const totalAbiertos   = allTickets.filter(t => t.estado === 'abierto').length;
const totalEnProceso  = allTickets.filter(t => t.estado === 'en_proceso').length;
const totalResueltos  = allTickets.filter(t => t.estado === 'resuelto').length;

function formatFecha(iso: string): string {
  return new Date(iso).toLocaleDateString('es-MX', {
    day: '2-digit', month: 'short', year: 'numeric',
  });
}

const CATEGORIA_LABELS: Record<string, string> = {
  queja:      'Queja',
  solicitud:  'Solicitud',
  sugerencia: 'Sugerencia',
};

const ESTADO_LABELS: Record<string, string> = {
  abierto:    'Abierto',
  en_proceso: 'En proceso',
  resuelto:   'Resuelto',
};
---

<Layout title="Solicitudes y Quejas">
  <div class="max-w-4xl mx-auto">

    <!-- Header -->
    <div class="mb-10 lg:mb-14">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-6">
        <div>
          <span class="inline-block text-[9px] font-black uppercase tracking-[0.5em] text-orange-500 bg-orange-50 border border-orange-200 rounded-full px-3 py-1 mb-4">
            Portal Vecinal
          </span>
          <h1 class="font-black text-4xl sm:text-5xl text-slate-900 tracking-tight leading-none mb-3"
              style="font-family: 'Outfit', sans-serif;">
            Solicitudes &<br/>Quejas
          </h1>
          <p class="text-slate-500 text-sm font-medium max-w-sm leading-relaxed">
            Comunica incidencias, solicitudes de servicio o sugerencias directamente a la Comisión de Vigilancia.
          </p>
        </div>

        <a
          href="/solicitudes/nuevo"
          class="inline-flex items-center gap-2.5 px-6 py-3.5 bg-orange-500 hover:bg-orange-600 text-white font-black text-[11px] uppercase tracking-[0.3em] rounded-2xl transition-all shadow-lg shadow-orange-200 hover:shadow-orange-300 hover:-translate-y-0.5 shrink-0"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
          </svg>
          Nueva solicitud
        </a>
      </div>

      <!-- Contadores -->
      <div class="mt-8 grid grid-cols-3 gap-3 sm:gap-4">
        <div class="bg-white border border-slate-100 rounded-2xl p-4 text-center shadow-sm">
          <div class="text-2xl sm:text-3xl font-black text-slate-900" style="font-family: 'Outfit', sans-serif;">{totalAbiertos}</div>
          <div class="text-[9px] font-black uppercase tracking-[0.35em] text-slate-400 mt-1">Abiertos</div>
        </div>
        <div class="bg-white border border-slate-100 rounded-2xl p-4 text-center shadow-sm">
          <div class="text-2xl sm:text-3xl font-black text-amber-500" style="font-family: 'Outfit', sans-serif;">{totalEnProceso}</div>
          <div class="text-[9px] font-black uppercase tracking-[0.35em] text-slate-400 mt-1">En proceso</div>
        </div>
        <div class="bg-white border border-slate-100 rounded-2xl p-4 text-center shadow-sm">
          <div class="text-2xl sm:text-3xl font-black text-emerald-500" style="font-family: 'Outfit', sans-serif;">{totalResueltos}</div>
          <div class="text-[9px] font-black uppercase tracking-[0.35em] text-slate-400 mt-1">Resueltos</div>
        </div>
      </div>
    </div>

    <!-- Lista de tickets -->
    {allTickets.length === 0 ? (
      <div class="text-center py-20 bg-white rounded-3xl border border-slate-100">
        <div class="w-16 h-16 rounded-2xl bg-slate-50 border border-slate-100 flex items-center justify-center mx-auto mb-5">
          <svg class="w-7 h-7 text-slate-300" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 9.75a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375m-13.5 3.01c0 1.6 1.123 2.994 2.707 3.227 1.087.16 2.185.283 3.293.369V21l4.184-4.183a1.14 1.14 0 0 1 .778-.332 48.294 48.294 0 0 0 5.83-.498c1.585-.233 2.708-1.626 2.708-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0 0 12 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018Z" />
          </svg>
        </div>
        <h3 class="font-black text-lg text-slate-700 mb-2" style="font-family: 'Outfit', sans-serif;">Sin solicitudes todavía</h3>
        <p class="text-sm text-slate-400 mb-6">Sé el primero en reportar una incidencia o hacer una sugerencia.</p>
        <a href="/solicitudes/nuevo" class="inline-flex items-center gap-2 px-5 py-2.5 bg-orange-500 text-white font-black text-[10px] uppercase tracking-widest rounded-xl hover:bg-orange-600 transition-colors">
          Crear primera solicitud
        </a>
      </div>
    ) : (
      <div class="flex flex-col gap-3">
        {allTickets.map((ticket) => (
          <a
            href={`/solicitudes/${ticket.id}`}
            class="group block bg-white border border-slate-100 hover:border-orange-200 rounded-2xl p-5 sm:p-6 transition-all hover:shadow-md hover:-translate-y-0.5"
          >
            <div class="flex items-start gap-4">
              <!-- Indicador de estado -->
              <div class:list={[
                "mt-1 w-2.5 h-2.5 rounded-full shrink-0",
                ticket.estado === 'abierto'    && "bg-slate-300",
                ticket.estado === 'en_proceso' && "bg-amber-400",
                ticket.estado === 'resuelto'   && "bg-emerald-400",
              ]}></div>

              <div class="flex-grow min-w-0">
                <div class="flex flex-wrap items-center gap-2 mb-2">
                  <!-- Categoría badge -->
                  <span class:list={[
                    "text-[9px] font-black uppercase tracking-[0.4em] px-2.5 py-1 rounded-full border",
                    ticket.categoria === 'queja'      && "text-red-600 bg-red-50 border-red-200",
                    ticket.categoria === 'solicitud'  && "text-blue-600 bg-blue-50 border-blue-200",
                    ticket.categoria === 'sugerencia' && "text-violet-600 bg-violet-50 border-violet-200",
                  ]}>
                    {CATEGORIA_LABELS[ticket.categoria]}
                  </span>
                  <!-- Estado badge -->
                  <span class:list={[
                    "text-[9px] font-black uppercase tracking-[0.35em] px-2.5 py-1 rounded-full border",
                    ticket.estado === 'abierto'    && "text-slate-500 bg-slate-50 border-slate-200",
                    ticket.estado === 'en_proceso' && "text-amber-600 bg-amber-50 border-amber-200",
                    ticket.estado === 'resuelto'   && "text-emerald-600 bg-emerald-50 border-emerald-200",
                  ]}>
                    {ESTADO_LABELS[ticket.estado]}
                  </span>
                </div>

                <h2 class="font-black text-slate-900 text-base sm:text-lg leading-tight tracking-tight mb-1 group-hover:text-orange-500 transition-colors"
                    style="font-family: 'Outfit', sans-serif;">
                  {ticket.titulo}
                </h2>

                <p class="text-slate-500 text-sm leading-relaxed line-clamp-2 mb-3">
                  {ticket.descripcion}
                </p>

                <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-[11px] font-bold text-slate-400 uppercase tracking-widest">
                  <span>Depto. {ticket.departamento}</span>
                  <span>·</span>
                  <span>{ticket.nombre}</span>
                  <span>·</span>
                  <span>{formatFecha(ticket.created_at)}</span>
                  {ticket.estado === 'resuelto' && ticket.respondido_por && (
                    <>
                      <span>·</span>
                      <span class="text-emerald-500">Respondido por {ticket.respondido_por}</span>
                    </>
                  )}
                </div>
              </div>

              <!-- Flecha -->
              <svg class="w-4 h-4 text-slate-300 group-hover:text-orange-400 shrink-0 mt-1 transition-colors" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
              </svg>
            </div>
          </a>
        ))}
      </div>
    )}

  </div>
</Layout>
