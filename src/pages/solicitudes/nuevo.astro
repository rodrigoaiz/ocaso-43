---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Nueva Solicitud">
  <div class="max-w-2xl mx-auto">

    <!-- Header -->
    <div class="mb-10">
      <a
        href="/solicitudes"
        class="inline-flex items-center gap-2 text-[10px] font-black uppercase tracking-[0.35em] text-slate-400 hover:text-orange-500 transition-colors mb-6"
      >
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
        </svg>
        Volver a solicitudes
      </a>

      <span class="inline-block text-[9px] font-black uppercase tracking-[0.5em] text-orange-500 bg-orange-50 border border-orange-200 rounded-full px-3 py-1 mb-4">
        Nueva solicitud
      </span>
      <h1 class="font-black text-4xl sm:text-5xl text-slate-900 tracking-tight leading-none mb-3"
          style="font-family: 'Outfit', sans-serif;">
        Reportar<br/>Incidencia
      </h1>
      <p class="text-slate-500 text-sm leading-relaxed max-w-sm">
        Tu solicitud será revisada por la Comisión de Vigilancia. Recibirás respuesta en la lista pública de solicitudes.
      </p>
    </div>

    <!-- Formulario -->
    <form id="ticket-form" class="flex flex-col gap-6">

      <!-- Categoría -->
      <div class="field-group">
        <label class="field-label">Tipo de solicitud <span class="text-orange-500">*</span></label>
        <div class="grid grid-cols-3 gap-3" role="radiogroup">
          <label class="categoria-option">
            <input type="radio" name="categoria" value="queja" required class="sr-only" />
            <div class="categoria-card">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
              </svg>
              <span>Queja</span>
            </div>
          </label>
          <label class="categoria-option">
            <input type="radio" name="categoria" value="solicitud" required class="sr-only" />
            <div class="categoria-card">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l5.654-4.654m5.292-5.292 2.496-3.03a1.75 1.75 0 0 0-2.475-2.475l-3.03 2.496" />
              </svg>
              <span>Solicitud</span>
            </div>
          </label>
          <label class="categoria-option">
            <input type="radio" name="categoria" value="sugerencia" required class="sr-only" />
            <div class="categoria-card">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 0 0 1.5-.189m-1.5.189a6.01 6.01 0 0 1-1.5-.189m3.75 7.478a12.06 12.06 0 0 1-4.5 0m3.75 2.383a14.406 14.406 0 0 1-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 1 0-7.517 0c.85.493 1.509 1.333 1.509 2.316V18" />
              </svg>
              <span>Sugerencia</span>
            </div>
          </label>
        </div>
      </div>

      <!-- Título -->
      <div class="field-group">
        <label for="titulo" class="field-label">Título <span class="text-orange-500">*</span></label>
        <input
          type="text"
          id="titulo"
          name="titulo"
          required
          maxlength="120"
          placeholder="Ej. Fuga de agua en área común"
          class="field-input"
        />
        <p class="text-[10px] text-slate-400 mt-1.5 font-medium">Describe el problema en una frase corta</p>
      </div>

      <!-- Descripción -->
      <div class="field-group">
        <label for="descripcion" class="field-label">Descripción <span class="text-orange-500">*</span></label>
        <textarea
          id="descripcion"
          name="descripcion"
          required
          rows="5"
          maxlength="2000"
          placeholder="Describe el problema con el mayor detalle posible: dónde ocurrió, cuándo lo notaste, qué impacto tiene..."
          class="field-input resize-none"
        ></textarea>
      </div>

      <!-- Nombre y Depto (en fila) -->
      <div class="grid grid-cols-2 gap-4">
        <div class="field-group">
          <label for="nombre" class="field-label">Tu nombre <span class="text-orange-500">*</span></label>
          <input
            type="text"
            id="nombre"
            name="nombre"
            required
            maxlength="80"
            placeholder="Nombre completo"
            class="field-input"
          />
        </div>
        <div class="field-group">
          <label for="departamento" class="field-label">Departamento <span class="text-orange-500">*</span></label>
          <input
            type="text"
            id="departamento"
            name="departamento"
            required
            maxlength="10"
            placeholder="Ej. 4B"
            class="field-input"
          />
        </div>
      </div>

      <!-- Error general -->
      <div id="form-error" class="hidden items-center gap-3 p-4 bg-red-50 border border-red-200 rounded-2xl text-red-700">
        <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
        </svg>
        <p id="form-error-msg" class="text-[11px] font-black uppercase tracking-widest"></p>
      </div>

      <!-- Submit -->
      <button
        type="submit"
        id="submit-btn"
        class="w-full flex items-center justify-center gap-3 py-4 px-6 bg-orange-500 hover:bg-orange-600 disabled:opacity-60 disabled:cursor-not-allowed text-white font-black text-[11px] uppercase tracking-[0.35em] rounded-2xl transition-all shadow-lg shadow-orange-200 hover:shadow-orange-300 hover:-translate-y-0.5 active:translate-y-0"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5" />
        </svg>
        <span id="submit-label">Enviar solicitud</span>
      </button>

      <p class="text-center text-[10px] font-bold text-slate-400 uppercase tracking-[0.3em]">
        Tu solicitud será visible para todos los residentes
      </p>

    </form>

  </div>
</Layout>

<style>
  .field-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .field-label {
    font-size: 0.625rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.35em;
    color: #475569;
  }

  .field-input {
    width: 100%;
    padding: 0.875rem 1rem;
    background: white;
    border: 1.5px solid #e2e8f0;
    border-radius: 14px;
    color: #0f172a;
    font-size: 0.9375rem;
    font-weight: 500;
    font-family: inherit;
    outline: none;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .field-input::placeholder { color: #cbd5e1; }

  .field-input:focus {
    border-color: #f97316;
    box-shadow: 0 0 0 3px rgba(249, 115, 22, 0.1);
  }

  /* Categoría radio cards */
  .categoria-option { cursor: pointer; }

  .categoria-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 0.75rem;
    background: white;
    border: 1.5px solid #e2e8f0;
    border-radius: 14px;
    color: #94a3b8;
    font-size: 0.7rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    transition: all 0.15s;
    text-align: center;
  }

  .categoria-option:hover .categoria-card {
    border-color: #f97316;
    color: #f97316;
  }

  /* Selected state via JS */
  .categoria-option.selected .categoria-card {
    border-color: #f97316;
    background: #fff7ed;
    color: #ea580c;
    box-shadow: 0 0 0 3px rgba(249, 115, 22, 0.12);
  }
</style>

<script>
  // Radio card visual selection
  const radios = document.querySelectorAll<HTMLInputElement>('input[name="categoria"]');
  radios.forEach(radio => {
    radio.addEventListener('change', () => {
      document.querySelectorAll('.categoria-option').forEach(opt => opt.classList.remove('selected'));
      radio.closest('.categoria-option')?.classList.add('selected');
    });
  });

  // Form submission
  const form = document.getElementById('ticket-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const submitLabel = document.getElementById('submit-label') as HTMLSpanElement;
  const errorBox = document.getElementById('form-error') as HTMLDivElement;
  const errorMsg = document.getElementById('form-error-msg') as HTMLParagraphElement;

  function showError(msg: string) {
    errorMsg.textContent = msg;
    errorBox.classList.remove('hidden');
    errorBox.classList.add('flex');
    errorBox.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  function hideError() {
    errorBox.classList.add('hidden');
    errorBox.classList.remove('flex');
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    hideError();

    const data = new FormData(form);
    const payload = {
      titulo:       (data.get('titulo') as string)?.trim(),
      descripcion:  (data.get('descripcion') as string)?.trim(),
      categoria:    data.get('categoria') as string,
      nombre:       (data.get('nombre') as string)?.trim(),
      departamento: (data.get('departamento') as string)?.trim(),
    };

    if (!payload.categoria) {
      showError('Selecciona el tipo de solicitud');
      return;
    }

    submitBtn.disabled = true;
    submitLabel.textContent = 'Enviando...';

    try {
      const res = await fetch('/api/tickets/crear', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      const json = await res.json();

      if (!res.ok) {
        showError(json.error ?? 'Error al enviar. Intenta de nuevo.');
        return;
      }

      // Redirigir al detalle del ticket recién creado
      window.location.href = `/solicitudes/${json.id}`;

    } catch {
      showError('Error de conexión. Verifica tu internet e intenta de nuevo.');
    } finally {
      submitBtn.disabled = false;
      submitLabel.textContent = 'Enviar solicitud';
    }
  });
</script>
