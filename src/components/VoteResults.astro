---
interface Voto {
  voto: 'a_favor' | 'en_contra';
  usuario: {
    username: string;
  };
}

interface Props {
  votos: Voto[];
  votosCount: number;
}

const { votos, votosCount } = Astro.props;

const aFavorCount = votos.filter(v => v.voto === 'a_favor').length;
const enContraCount = votos.filter(v => v.voto === 'en_contra').length;
---

<div class="rounded-[2rem] bg-gradient-to-br from-emerald-50 to-slate-50 p-6 border-2 border-emerald-200 shadow-lg">
  <h3 class="font-black text-xl text-emerald-900 mb-4">
    ✅ Resultados de la Votación
  </h3>
  
  <!-- Votos individuales -->
  <div class="space-y-2 mb-4">
    {votos.map((voto) => (
      <div class="vote-result-row">
        <span class="font-bold text-slate-700 capitalize">
          {voto.usuario.username}
        </span>
        <span class={voto.voto === 'a_favor' ? 'vote-badge-a-favor' : 'vote-badge-en-contra'}>
          {voto.voto === 'a_favor' ? '👍 A favor' : '👎 En contra'}
        </span>
      </div>
    ))}
  </div>
  
  <!-- Resumen -->
  <div class="grid grid-cols-2 gap-4 pt-4 border-t-2 border-emerald-200">
    <div class="text-center">
      <p class="text-4xl font-black text-emerald-600 mb-1">{aFavorCount}</p>
      <p class="text-xs font-bold text-emerald-700 uppercase tracking-wide">A favor</p>
    </div>
    <div class="text-center">
      <p class="text-4xl font-black text-red-600 mb-1">{enContraCount}</p>
      <p class="text-xs font-bold text-red-700 uppercase tracking-wide">En contra</p>
    </div>
  </div>
  
  <!-- Nota de quórum -->
  {votosCount === 2 && (
    <p class="text-slate-600 text-xs mt-4 text-center bg-amber-50 rounded-xl p-2 border border-amber-200">
      ℹ️ Quórum alcanzado. Falta 1 voto para completar.
    </p>
  )}
  
  {votosCount === 3 && (
    <p class="text-emerald-700 text-xs mt-4 text-center bg-emerald-100 rounded-xl p-2 border border-emerald-300 font-bold">
      ✅ Votación completa - Todos los miembros han votado
    </p>
  )}
</div>
