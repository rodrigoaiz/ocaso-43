---
import type { CollectionEntry } from "astro:content";

interface Props {
  proyecto: CollectionEntry<"proyectos-votacion">;
}

const { proyecto } = Astro.props;
const { data } = proyecto;

const formatMonto = (monto: number) =>
  new Intl.NumberFormat("es-MX", {
    style: "currency",
    currency: "MXN",
    minimumFractionDigits: 0,
  }).format(monto);

const categoriaIcons: Record<string, string> = {
  "Seguridad": "🔒",
  "Mantenimiento": "🔧",
  "Compras y Suministros": "🛒",
  "Compras": "🛒",
  "Mejoras": "✨",
  "Reparaciones": "🏗️",
  "Emergencias": "🚨",
};
const icon = data.categoria ? (categoriaIcons[data.categoria] ?? "📋") : "📋";
---

<article class="rounded-[2rem] overflow-hidden border border-slate-200 bg-white shadow-sm">

  <!-- Header -->
  <div class="bg-slate-900 px-6 py-5 flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3">
    <div class="flex-1 min-w-0">
      <div class="flex flex-wrap items-center gap-2 mb-2">
        {data.categoria && (
          <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-orange-500/20 border border-orange-500/30 text-orange-300 text-[10px] font-black uppercase tracking-widest">
            <span>{icon}</span>
            {data.categoria}
          </span>
        )}
        <span class="inline-flex items-center px-3 py-1 rounded-full bg-white/10 text-slate-400 text-[10px] font-black uppercase tracking-widest">
          En consideración
        </span>
      </div>
      <h3 class="text-xl sm:text-2xl font-black text-white tracking-tight leading-tight">
        {data.titulo}
      </h3>
      {data.descripcion_corta && (
        <p class="mt-1.5 text-sm text-slate-400 font-medium leading-relaxed">
          {data.descripcion_corta}
        </p>
      )}
    </div>

    {data.presupuesto_estimado && (
      <div class="shrink-0 text-right">
        <div class="text-[10px] font-black uppercase tracking-[0.3em] text-slate-500 mb-0.5">
          Presupuesto est.
        </div>
        <div class="text-2xl sm:text-3xl font-black text-orange-400 leading-none">
          {formatMonto(data.presupuesto_estimado)}
        </div>
      </div>
    )}
  </div>

  <!-- Body -->
  <div class="px-6 py-5">

    <!-- Proveedor -->
    {data.proveedor && (
      <div class="flex items-center gap-2 mb-4 text-sm text-slate-500 font-medium">
        <svg class="w-4 h-4 text-slate-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 21v-7.5a.75.75 0 0 1 .75-.75h3a.75.75 0 0 1 .75.75V21m-4.5 0H2.36m11.14 0H18m0 0h3.64m-1.39 0V9.349M3.75 21V9.349m0 0a3.001 3.001 0 0 0 3.75-.615A2.993 2.993 0 0 0 9.75 9.75c.896 0 1.7-.393 2.25-1.016a2.993 2.993 0 0 0 2.25 1.016c.896 0 1.7-.393 2.25-1.015a3.001 3.001 0 0 0 3.75.614m-16.5 0a3.004 3.004 0 0 1-.621-4.72l1.189-1.19A1.5 1.5 0 0 1 5.378 3h13.243a1.5 1.5 0 0 1 1.06.44l1.19 1.189a3 3 0 0 1-.621 4.72M6.75 18h3.75a.75.75 0 0 0 .75-.75V13.5a.75.75 0 0 0-.75-.75H6.75a.75.75 0 0 0-.75.75v3.75c0 .414.336.75.75.75Z" />
        </svg>
        <span>Proveedor: <strong class="text-slate-700">{data.proveedor}</strong></span>
      </div>
    )}

    <!-- Opciones para tipo seleccion -->
    {data.tipo_votacion === "seleccion" && data.opciones_votacion && data.opciones_votacion.length > 0 && (
      <div>
        <p class="text-[10px] font-black uppercase tracking-[0.4em] text-slate-400 mb-3">
          Opciones en evaluación
        </p>
        <div class="grid sm:grid-cols-2 gap-3">
          {data.opciones_votacion.map((opcion, i) => (
            <div class="flex flex-col gap-1.5 p-4 rounded-2xl bg-slate-50 border border-slate-100">
              <div class="flex items-start justify-between gap-2">
                <div class="flex items-center gap-2 min-w-0">
                  <span class="w-6 h-6 rounded-lg bg-slate-200 text-slate-600 text-[10px] font-black flex items-center justify-center shrink-0">
                    {i + 1}
                  </span>
                  <span class="font-black text-slate-900 text-sm leading-tight">
                    {opcion.nombre}
                  </span>
                </div>
                {opcion.precio && (
                  <span class="shrink-0 text-sm font-black text-orange-500">
                    {formatMonto(opcion.precio)}
                  </span>
                )}
              </div>
              {opcion.descripcion_corta && (
                <p class="text-xs text-slate-500 font-medium leading-relaxed pl-8">
                  {opcion.descripcion_corta}
                </p>
              )}
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Para tipo binaria sin opciones: solo nota informativa -->
    {data.tipo_votacion === "binaria" && !data.proveedor && !data.presupuesto_estimado && (
      <p class="text-xs text-slate-400 font-medium italic">
        Proyecto en evaluación por la Comisión de Vigilancia.
      </p>
    )}

  </div>

  <!-- Footer -->
  <div class="px-6 py-3 border-t border-slate-100 flex items-center gap-2">
    <svg class="w-3.5 h-3.5 text-slate-300 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
    </svg>
    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">
      Revisado por la Comisión de Vigilancia
    </p>
  </div>

</article>
