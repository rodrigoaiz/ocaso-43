---
import type { CollectionEntry } from "astro:content";

interface Props {
  proyecto: CollectionEntry<"proyectos-votacion">;
}

const { proyecto } = Astro.props;
const { data } = proyecto;

const formatMonto = (monto: number) =>
  new Intl.NumberFormat("es-MX", {
    style: "currency",
    currency: "MXN",
    minimumFractionDigits: 0,
  }).format(monto);

// Lógica de presupuesto: rango o valor único
const hasRange = data.presupuesto_min != null || data.presupuesto_max != null;
const presupuestoDisplay = (() => {
  if (hasRange) {
    if (data.presupuesto_min != null && data.presupuesto_max != null) {
      return `${formatMonto(data.presupuesto_min)} – ${formatMonto(data.presupuesto_max)}`;
    }
    if (data.presupuesto_max != null) return `hasta ${formatMonto(data.presupuesto_max)}`;
    if (data.presupuesto_min != null) return `desde ${formatMonto(data.presupuesto_min)}`;
  }
  if (data.presupuesto_estimado != null) return formatMonto(data.presupuesto_estimado);
  return null;
})();
const isRange = hasRange && data.presupuesto_min != null && data.presupuesto_max != null;

const hasOpciones = data.tipo_votacion === "seleccion" && data.opciones_votacion && data.opciones_votacion.length > 0;
const hasBodyContent = hasOpciones || data.proveedor;
---

<a
  href={`/proyectos/${proyecto.slug}`}
  class="group block rounded-[2rem] overflow-hidden border border-slate-200 bg-white shadow-sm hover:shadow-xl hover:shadow-violet-500/5 hover:border-violet-200 transition-all duration-200 hover:-translate-y-0.5"
>
  <div class="flex flex-col md:flex-row">

    <!-- Columna izquierda: fondo oscuro — título, pills, presupuesto -->
    <div class="bg-slate-900 px-7 py-7 md:w-80 lg:w-96 shrink-0 flex flex-col justify-between gap-6">
      <div>
        <!-- Pills -->
        <div class="flex flex-wrap items-center gap-2 mb-4">
          {data.categoria && (
            <span class="inline-flex items-center px-3 py-1 rounded-full bg-orange-500/20 border border-orange-500/30 text-orange-300 text-[10px] font-black uppercase tracking-widest">
              {data.categoria}
            </span>
          )}
          <span class="inline-flex items-center px-3 py-1 rounded-full bg-white/10 text-slate-400 text-[10px] font-black uppercase tracking-widest">
            En consideración
          </span>
          {data.tipo_votacion === 'seleccion' && (
            <span class="inline-flex items-center px-3 py-1 rounded-full bg-violet-500/20 border border-violet-500/30 text-violet-300 text-[10px] font-black uppercase tracking-widest">
              Selección
            </span>
          )}
        </div>

        <!-- Título -->
        <h3 class="text-xl lg:text-2xl font-black text-white tracking-tight leading-tight group-hover:text-orange-300 transition-colors">
          {data.titulo}
        </h3>
        {data.descripcion_corta && (
          <p class="text-sm text-slate-400 font-medium leading-relaxed mt-2">
            {data.descripcion_corta}
          </p>
        )}
      </div>

      <!-- Presupuesto -->
      {presupuestoDisplay && (
        <div class="pt-5 border-t border-white/10">
          <p class="text-[10px] font-black uppercase tracking-[0.3em] text-slate-500 mb-1">
            {isRange ? "Rango estimado" : "Presupuesto est."}
          </p>
          <p class={`font-black text-orange-400 leading-none ${isRange ? "text-lg" : "text-2xl"}`}>
            {presupuestoDisplay}
          </p>
        </div>
      )}
    </div>

    <!-- Columna derecha: contenido + footer -->
    <div class="flex flex-col flex-1 min-w-0">
      <div class="flex-1 px-7 py-7">

        <!-- Proveedor -->
        {data.proveedor && (
          <div class="flex items-center gap-2 mb-5 text-sm text-slate-500 font-medium">
            <svg class="w-4 h-4 text-slate-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 21v-7.5a.75.75 0 0 1 .75-.75h3a.75.75 0 0 1 .75.75V21m-4.5 0H2.36m11.14 0H18m0 0h3.64m-1.39 0V9.349M3.75 21V9.349m0 0a3.001 3.001 0 0 0 3.75-.615A2.993 2.993 0 0 0 9.75 9.75c.896 0 1.7-.393 2.25-1.016a2.993 2.993 0 0 0 2.25 1.016c.896 0 1.7-.393 2.25-1.015a3.001 3.001 0 0 0 3.75.614m-16.5 0a3.004 3.004 0 0 1-.621-4.72l1.189-1.19A1.5 1.5 0 0 1 5.378 3h13.243a1.5 1.5 0 0 1 1.06.44l1.19 1.189a3 3 0 0 1-.621 4.72M6.75 18h3.75a.75.75 0 0 0 .75-.75V13.5a.75.75 0 0 0-.75-.75H6.75a.75.75 0 0 0-.75.75v3.75c0 .414.336.75.75.75Z" />
            </svg>
            <span>Proveedor: <strong class="text-slate-700">{data.proveedor}</strong></span>
          </div>
        )}

        <!-- Opciones de selección -->
        {hasOpciones && (
          <div>
            <p class="text-[10px] font-black uppercase tracking-[0.4em] text-slate-400 mb-3">
              Opciones en evaluación
            </p>
            <div class="flex flex-col gap-2">
              {data.opciones_votacion!.map((opcion, i) => (
                <div class="flex items-start gap-3 px-4 py-3 rounded-xl bg-slate-50 border border-slate-100">
                  <span class="w-5 h-5 rounded-md bg-slate-200 text-slate-600 text-[10px] font-black flex items-center justify-center shrink-0 mt-0.5">
                    {i + 1}
                  </span>
                  <div class="min-w-0">
                    <p class="font-black text-slate-900 text-sm leading-tight">{opcion.nombre}</p>
                    {opcion.descripcion_corta && (
                      <p class="text-xs text-slate-500 font-medium leading-relaxed mt-0.5">{opcion.descripcion_corta}</p>
                    )}
                    {opcion.precio && (
                      <p class="text-xs font-black text-orange-500 mt-1">{formatMonto(opcion.precio)}</p>
                    )}
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}

        <!-- Fallback: sin contenido extra -->
        {!hasBodyContent && (
          <p class="text-sm text-slate-400 font-medium italic">
            Proyecto en evaluación por la Comisión de Vigilancia.
          </p>
        )}
      </div>

      <!-- Footer -->
      <div class="px-7 py-4 border-t border-slate-100 flex items-center justify-between gap-2">
        <div class="flex items-center gap-2">
          <svg class="w-3.5 h-3.5 text-slate-300 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">
            Revisado por la Comisión de Vigilancia
          </p>
        </div>
        <span class="text-[10px] font-black uppercase tracking-widest text-violet-400 group-hover:text-violet-600 transition-colors flex items-center gap-1">
          Ver detalle
          <span class="group-hover:translate-x-0.5 transition-transform inline-block">→</span>
        </span>
      </div>
    </div>

  </div>
</a>
