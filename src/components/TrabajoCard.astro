---
/**
 * TrabajoCard - Card component for displaying completed work in list view
 * Shows: image, title, category, date, cost, provider
 */

interface Props {
  slug: string;
  titulo: string;
  categoria: string;
  fecha_realizacion: Date;
  costo_final: number;
  proveedor: string;
  descripcion_corta: string;
  imagen_principal?: string;
  proyecto_slug?: string;
}

const {
  slug,
  titulo,
  categoria,
  fecha_realizacion,
  costo_final,
  proveedor,
  descripcion_corta,
  imagen_principal,
  proyecto_slug,
} = Astro.props;

const categoriaColors: Record<string, string> = {
  Mantenimiento: 'bg-slate-100 text-slate-700',
  Compras: 'bg-orange-100 text-orange-700',
  Mejoras: 'bg-pink-100 text-pink-700',
  Emergencias: 'bg-red-100 text-red-700',
  Reparaciones: 'bg-amber-100 text-amber-700',
};

const categoriaColor = categoriaColors[categoria] || categoriaColors.Mantenimiento;

const formattedDate = fecha_realizacion.toLocaleDateString('es-MX', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedCost = new Intl.NumberFormat('es-MX', {
  style: 'currency',
  currency: 'MXN',
  minimumFractionDigits: 0,
}).format(costo_final);
---

<a
  href={`/trabajos/${slug}`}
  class="group block p-6 rounded-3xl bg-white border border-slate-100 hover:border-orange-200 transition-all shadow-sm hover:shadow-xl hover:shadow-orange-500/5"
>
  <div class="flex flex-col sm:flex-row gap-6">
    <!-- Image Section -->
    {
      imagen_principal && (
        <div class="w-full sm:w-48 h-48 shrink-0 rounded-2xl overflow-hidden bg-slate-50">
          <img
            src={imagen_principal}
            alt={titulo}
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
          />
        </div>
      )
    }

    <!-- Content Section -->
    <div class="flex-grow flex flex-col justify-between">
      <div>
        <!-- Category + Project Badge -->
        <div class="flex flex-wrap items-center gap-2 mb-3">
          <span
            class={`inline-block px-3 py-1 rounded-lg text-[10px] font-black uppercase tracking-widest ${categoriaColor}`}
          >
            {categoria}
          </span>
          {
            proyecto_slug && (
              <span class="inline-block px-3 py-1 rounded-lg text-[10px] font-black uppercase tracking-widest bg-green-100 text-green-700">
                ✓ Aprobado por Comisión
              </span>
            )
          }
        </div>

        <!-- Title -->
        <h3
          class="text-xl font-black text-slate-900 group-hover:text-orange-500 transition-colors mb-2"
        >
          {titulo}
        </h3>

        <!-- Description -->
        <p class="text-slate-500 text-sm line-clamp-2 font-medium mb-4">
          {descripcion_corta}
        </p>
      </div>

      <!-- Metadata Grid -->
      <div class="grid grid-cols-2 gap-4 pt-4 border-t border-slate-100">
        <!-- Cost -->
        <div>
          <p class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-1">
            Costo Final
          </p>
          <p class="text-2xl font-black text-orange-500">{formattedCost}</p>
        </div>

        <!-- Date -->
        <div>
          <p class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-1">
            Realizado
          </p>
          <p class="text-sm font-bold text-slate-700">{formattedDate}</p>
        </div>

        <!-- Provider -->
        <div class="col-span-2">
          <p class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-1">
            Proveedor
          </p>
          <p class="text-sm font-bold text-slate-700">{proveedor}</p>
        </div>
      </div>
    </div>

    <!-- Arrow indicator -->
    <div
      class="self-center text-slate-300 group-hover:text-orange-500 transition-all font-black text-2xl group-hover:translate-x-2"
    >
      &rarr;
    </div>
  </div>
</a>
