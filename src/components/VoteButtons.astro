---
interface Props {
  slug: string;
}

const { slug } = Astro.props;
---

<div id="vote-buttons" class="voting-section bg-gradient-to-br from-slate-50 to-slate-100 rounded-[2rem] p-8 shadow-xl border-2 border-slate-200" data-slug={slug}>
  <div class="text-center mb-8">
    <h3 class="font-black text-3xl mb-3 text-slate-900">🗳️ Emite tu voto</h3>
    <p class="text-slate-600 text-lg">Selecciona tu posición sobre este proyecto</p>
  </div>
  
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
    <button
      id="btn-a-favor"
      class="vote-button vote-button-favor group relative overflow-hidden px-8 py-8 rounded-[1.5rem] shadow-lg transition-all duration-300 hover:scale-105 hover:shadow-2xl disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:scale-100"
      data-voto="a_favor"
    >
      <div class="relative z-10">
        <div class="text-5xl mb-3">👍</div>
        <div class="font-black text-2xl mb-2">A FAVOR</div>
        <div class="text-sm opacity-90">Aprobar este proyecto</div>
      </div>
      <div class="absolute inset-0 bg-gradient-to-br from-green-400/20 to-emerald-500/20 opacity-0 group-hover:opacity-100 transition-opacity"></div>
    </button>
    
    <button
      id="btn-en-contra"
      class="vote-button vote-button-contra group relative overflow-hidden px-8 py-8 rounded-[1.5rem] shadow-lg transition-all duration-300 hover:scale-105 hover:shadow-2xl disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:scale-100"
      data-voto="en_contra"
    >
      <div class="relative z-10">
        <div class="text-5xl mb-3">👎</div>
        <div class="font-black text-2xl mb-2">EN CONTRA</div>
        <div class="text-sm opacity-90">Rechazar este proyecto</div>
      </div>
      <div class="absolute inset-0 bg-gradient-to-br from-red-400/20 to-rose-500/20 opacity-0 group-hover:opacity-100 transition-opacity"></div>
    </button>
  </div>
  
  <div class="bg-amber-50 border-2 border-amber-200 rounded-xl p-4 text-center">
    <p class="text-amber-800 font-bold flex items-center justify-center gap-2">
      <span class="text-xl">⚠️</span>
      <span>Los votos son definitivos y no pueden cambiarse</span>
    </p>
  </div>
  
  <div id="vote-message" class="hidden mt-6"></div>
</div>

<script>
  const voteButtons = document.getElementById('vote-buttons');
  const btnAFavor = document.getElementById('btn-a-favor') as HTMLButtonElement;
  const btnEnContra = document.getElementById('btn-en-contra') as HTMLButtonElement;
  const messageDiv = document.getElementById('vote-message');
  
  if (voteButtons && btnAFavor && btnEnContra && messageDiv) {
    const slug = voteButtons.dataset.slug;
    
    const handleVote = async (voto: string) => {
      // Deshabilitar botones
      btnAFavor.disabled = true;
      btnEnContra.disabled = true;
      btnAFavor.classList.add('btn-loading');
      btnEnContra.classList.add('btn-loading');
      
      try {
        const response = await fetch('/api/votar', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            proyectoSlug: slug,
            voto: voto,
          }),
        });
        
        const result = await response.json();
        
        if (result.success) {
          // Mostrar mensaje de éxito
          messageDiv.className = 'mt-4 p-4 bg-emerald-100 border-2 border-emerald-300 rounded-xl text-emerald-800 text-center';
          messageDiv.textContent = '✅ Tu voto ha sido registrado exitosamente';
          messageDiv.classList.remove('hidden');
          
          // Recargar página después de 2 segundos para mostrar resultados
          setTimeout(() => {
            window.location.reload();
          }, 2000);
        } else {
          throw new Error(result.error || 'Error al registrar voto');
        }
      } catch (error) {
        // Mostrar error
        messageDiv.className = 'mt-4 p-4 bg-red-100 border-2 border-red-300 rounded-xl text-red-800 text-center';
        messageDiv.textContent = `❌ Error: ${error instanceof Error ? error.message : 'Error desconocido'}`;
        messageDiv.classList.remove('hidden');
        
        // Rehabilitar botones en caso de error
        btnAFavor.disabled = false;
        btnEnContra.disabled = false;
        btnAFavor.classList.remove('btn-loading');
        btnEnContra.classList.remove('btn-loading');
      }
    };
    
    btnAFavor.addEventListener('click', () => handleVote('a_favor'));
    btnEnContra.addEventListener('click', () => handleVote('en_contra'));
  }
</script>
