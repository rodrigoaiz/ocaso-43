---
import type { OpcionProducto } from '../lib/supabase';

interface Props {
  slug: string;
  userRol: 'votante' | 'observador';
  tipoVotacion: 'binaria' | 'seleccion';
  opciones?: OpcionProducto[];
}

const { slug, userRol, tipoVotacion, opciones = [] } = Astro.props;
const isObservador = userRol === 'observador';
---

<div id="vote-buttons" class="voting-section bg-gradient-to-br from-slate-50 to-slate-100 rounded-[2rem] p-6 shadow-lg border-2 border-slate-200" data-slug={slug} data-tipo={tipoVotacion}>
  {isObservador && (
    <div class="bg-blue-50 border-2 border-blue-200 rounded-xl p-3 mb-4 text-center">
      <p class="text-blue-800 font-bold text-sm flex items-center justify-center gap-2">
        <span class="text-lg">👁️</span>
        <span>Tienes acceso como observador. Solo puedes ver las votaciones, no votar.</span>
      </p>
    </div>
  )}
  
  {tipoVotacion === 'binaria' ? (
    <>
      <div class="text-center mb-6">
        <h3 class="font-black text-2xl mb-2 text-slate-900">🗳️ Emite tu voto</h3>
        <p class="text-slate-600 text-base">Selecciona tu posición sobre este proyecto</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
        <button
          id="btn-a-favor"
          class="vote-button vote-button-favor group relative overflow-hidden px-6 py-6 rounded-[1.5rem] shadow-lg transition-all duration-300 hover:scale-105 hover:shadow-2xl disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:scale-100"
          data-voto="a_favor"
          disabled={isObservador}
        >
          <div class="relative z-10">
            <div class="text-4xl mb-2">👍</div>
            <div class="font-black text-xl mb-1">A FAVOR</div>
            <div class="text-xs opacity-90">Aprobar este proyecto</div>
          </div>
          <div class="absolute inset-0 bg-gradient-to-br from-green-400/20 to-emerald-500/20 opacity-0 group-hover:opacity-100 transition-opacity"></div>
        </button>
        
        <button
          id="btn-en-contra"
          class="vote-button vote-button-contra group relative overflow-hidden px-6 py-6 rounded-[1.5rem] shadow-lg transition-all duration-300 hover:scale-105 hover:shadow-2xl disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:scale-100"
          data-voto="en_contra"
          disabled={isObservador}
        >
          <div class="relative z-10">
            <div class="text-4xl mb-2">👎</div>
            <div class="font-black text-xl mb-1">EN CONTRA</div>
            <div class="text-xs opacity-90">Rechazar este proyecto</div>
          </div>
          <div class="absolute inset-0 bg-gradient-to-br from-red-400/20 to-rose-500/20 opacity-0 group-hover:opacity-100 transition-opacity"></div>
        </button>
      </div>
    </>
  ) : (
    <>
      <div class="text-center mb-6">
        <h3 class="font-black text-2xl mb-2 text-slate-900">🛍️ Selecciona una opción</h3>
        <p class="text-slate-600 text-base">Elige el producto que prefieres</p>
      </div>
      
      <div class="grid gap-4 mb-4">
        {opciones.map((opcion) => (
          <button
            class="vote-option-card group relative overflow-hidden bg-white border-2 border-slate-200 rounded-[1.5rem] p-6 transition-all duration-300 hover:border-orange-400 hover:shadow-xl hover:scale-105 active:scale-95 disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:scale-100"
            data-opcion-id={opcion.id}
            disabled={isObservador}
          >
            <div class="flex items-start justify-between">
              <div class="flex-1">
                <div class="font-black text-lg text-slate-900 mb-1">
                  {opcion.nombre}
                </div>
                {opcion.descripcion_corta && (
                  <div class="text-sm text-slate-600 mb-2">
                    {opcion.descripcion_corta}
                  </div>
                )}
              </div>
              {opcion.precio && (
                <div class="ml-4 text-right">
                  <div class="font-black text-xl text-green-600">
                    ${opcion.precio}
                  </div>
                  <div class="text-xs text-slate-500">MXN</div>
                </div>
              )}
            </div>
            <div class="absolute inset-0 bg-gradient-to-br from-orange-400/10 to-pink-500/10 opacity-0 group-hover:opacity-100 transition-opacity"></div>
          </button>
        ))}
      </div>
    </>
  )}
  
  <div class="bg-amber-50 border-2 border-amber-200 rounded-xl p-3 text-center">
    <p class="text-amber-800 font-bold text-xs flex items-center justify-center gap-2">
      <span class="text-xl">⚠️</span>
      <span>Los votos son definitivos y no pueden cambiarse</span>
    </p>
  </div>
  
  <div id="vote-message" class="hidden mt-6"></div>
</div>

<script>
  const voteButtons = document.getElementById('vote-buttons');
  const messageDiv = document.getElementById('vote-message');
  
  if (voteButtons && messageDiv) {
    const slug = voteButtons.dataset.slug;
    const tipoVotacion = voteButtons.dataset.tipo;
    
    if (tipoVotacion === 'binaria') {
      // Votación binaria (código actual)
      const btnAFavor = document.getElementById('btn-a-favor') as HTMLButtonElement;
      const btnEnContra = document.getElementById('btn-en-contra') as HTMLButtonElement;
      
      if (btnAFavor && btnEnContra) {
        const handleVote = async (voto: string) => {
          // Deshabilitar botones
          btnAFavor.disabled = true;
          btnEnContra.disabled = true;
          btnAFavor.classList.add('btn-loading');
          btnEnContra.classList.add('btn-loading');
          
          try {
            const response = await fetch('/api/votar', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                proyectoSlug: slug,
                voto: voto,
              }),
            });
            
            const result = await response.json();
            
            if (result.success) {
              messageDiv.className = 'mt-4 p-4 bg-emerald-100 border-2 border-emerald-300 rounded-xl text-emerald-800 text-center';
              messageDiv.textContent = '✅ Tu voto ha sido registrado exitosamente';
              messageDiv.classList.remove('hidden');
              
              setTimeout(() => {
                window.location.reload();
              }, 2000);
            } else {
              throw new Error(result.error || 'Error al registrar voto');
            }
          } catch (error) {
            messageDiv.className = 'mt-4 p-4 bg-red-100 border-2 border-red-300 rounded-xl text-red-800 text-center';
            messageDiv.textContent = `❌ Error: ${error instanceof Error ? error.message : 'Error desconocido'}`;
            messageDiv.classList.remove('hidden');
            
            btnAFavor.disabled = false;
            btnEnContra.disabled = false;
            btnAFavor.classList.remove('btn-loading');
            btnEnContra.classList.remove('btn-loading');
          }
        };
        
        btnAFavor.addEventListener('click', () => handleVote('a_favor'));
        btnEnContra.addEventListener('click', () => handleVote('en_contra'));
      }
    } else if (tipoVotacion === 'seleccion') {
      // Votación de selección (nuevo)
      const opcionCards = document.querySelectorAll('.vote-option-card') as NodeListOf<HTMLButtonElement>;
      
      opcionCards.forEach(card => {
        card.addEventListener('click', async () => {
          const opcionId = card.dataset.opcionId;
          
          if (!opcionId) return;
          
          // Deshabilitar todas las opciones
          opcionCards.forEach(c => c.disabled = true);
          
          try {
            const response = await fetch('/api/votar', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                proyectoSlug: slug,
                opcionProductoId: opcionId,
              }),
            });
            
            const result = await response.json();
            
            if (result.success) {
              messageDiv.className = 'mt-4 p-4 bg-emerald-100 border-2 border-emerald-300 rounded-xl text-emerald-800 text-center';
              messageDiv.textContent = '✅ Tu voto ha sido registrado exitosamente';
              messageDiv.classList.remove('hidden');
              
              setTimeout(() => {
                window.location.reload();
              }, 2000);
            } else {
              throw new Error(result.error || 'Error al registrar voto');
            }
          } catch (error) {
            messageDiv.className = 'mt-4 p-4 bg-red-100 border-2 border-red-300 rounded-xl text-red-800 text-center';
            messageDiv.textContent = `❌ Error: ${error instanceof Error ? error.message : 'Error desconocido'}`;
            messageDiv.classList.remove('hidden');
            
            // Rehabilitar botones
            opcionCards.forEach(c => c.disabled = false);
          }
        });
      });
    }
  }
</script>
