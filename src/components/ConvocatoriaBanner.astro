---
import type { CollectionEntry } from "astro:content";
import { render } from "astro:content";

interface Props {
  convocatoria: CollectionEntry<"convocatorias">;
}

const { convocatoria } = Astro.props;
const { data } = convocatoria;
const { Content } = await render(convocatoria);

const assemblyDate = data.assemblyDate;
const day = assemblyDate.getDate().toString().padStart(2, "0");
const monthLong = assemblyDate.toLocaleDateString("es-MX", { month: "long" });
const monthShort = assemblyDate.toLocaleDateString("es-MX", { month: "short" }).toUpperCase();
const year = assemblyDate.getFullYear();
const weekday = assemblyDate.toLocaleDateString("es-MX", { weekday: "long" });

const assemblyTypeLabel =
  data.assemblyType === "ordinaria" ? "Ordinaria" : "Extraordinaria";

const modalId = `convocatoria-modal-${convocatoria.id.replace(/[^a-z0-9]/gi, "-")}`;
---

<!-- Banner de Convocatoria -->
<div
  class="convocatoria-banner mb-12 lg:mb-16 rounded-[2rem] overflow-hidden relative"
  role="region"
  aria-label="Convocatoria de Asamblea"
>
  <!-- Fondo oscuro con patrón de puntos sutil -->
  <div class="absolute inset-0 bg-slate-900">
    <svg class="absolute inset-0 w-full h-full opacity-[0.04]" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="dots" x="0" y="0" width="24" height="24" patternUnits="userSpaceOnUse">
          <circle cx="2" cy="2" r="1.5" fill="white"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#dots)"/>
    </svg>
    <!-- Resplandor naranja en esquina superior derecha -->
    <div class="absolute -top-20 -right-20 w-80 h-80 bg-orange-500/5 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute -bottom-10 -left-10 w-48 h-48 bg-amber-500/5 rounded-full blur-2xl pointer-events-none"></div>
  </div>

  <!-- Contenido -->
  <div class="relative z-10 flex flex-col lg:flex-row">

    <!-- Bloque izquierdo: fecha gigante -->
    <div class="flex-shrink-0 flex flex-row lg:flex-col items-center lg:items-start justify-between lg:justify-start gap-4 lg:gap-0 px-8 py-8 lg:py-10 lg:pr-0 lg:w-56 border-b lg:border-b-0 lg:border-r border-white/10">
      <!-- Etiqueta convocatoria -->
      <div class="flex flex-col gap-2">
        <span class="inline-block text-[9px] font-black uppercase tracking-[0.5em] text-orange-400 bg-orange-500/15 border border-orange-500/30 rounded-full px-3 py-1 w-fit">
          Convocatoria
        </span>
        <span class="text-[9px] font-black uppercase tracking-[0.35em] text-slate-500 w-fit">
          Asamblea {assemblyTypeLabel}
        </span>
      </div>
      <!-- Fecha grande solo en desktop -->
      <div class="hidden lg:flex flex-col mt-8">
        <span class="text-[9px] font-black uppercase tracking-[0.4em] text-orange-400/70 leading-none mb-1">{monthShort}</span>
        <span class="text-[7rem] font-black text-white leading-none tracking-tighter">{day}</span>
        <span class="text-sm font-black text-slate-500 uppercase tracking-widest leading-none -mt-1">{year}</span>
      </div>
      <!-- Fecha compacta solo en mobile -->
      <div class="flex lg:hidden items-center gap-3">
        <div class="w-14 h-14 rounded-2xl bg-orange-500 flex flex-col items-center justify-center shadow-lg shadow-orange-500/40">
          <span class="text-[8px] font-black text-orange-200 uppercase tracking-wider leading-none">{monthShort}</span>
          <span class="text-2xl font-black text-white leading-none mt-0.5">{day}</span>
          <span class="text-[8px] font-black text-orange-200 leading-none mt-0.5">{year}</span>
        </div>
      </div>
    </div>

    <!-- Bloque derecho: info + acciones -->
    <div class="flex-grow flex flex-col justify-between gap-6 p-8 lg:p-10">
      <!-- Título y detalles -->
      <div>
        <h2 class="text-2xl sm:text-3xl lg:text-4xl font-black text-white tracking-tight leading-tight mb-5">
          {data.title}
        </h2>
        <div class="flex flex-col sm:flex-row flex-wrap gap-y-2.5 gap-x-6">
          <span class="flex items-center gap-2 text-sm font-medium text-slate-400">
            <svg class="w-4 h-4 text-orange-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
            </svg>
            <span class="capitalize text-white/80">{weekday} {day} de {monthLong} de {year}</span>
          </span>
          <span class="flex items-center gap-2 text-sm font-medium text-slate-400">
            <svg class="w-4 h-4 text-orange-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
            </svg>
            <span class="text-white/80">1a: <strong class="text-orange-400 font-black">{data.firstCallTime}</strong> · 2a: {data.secondCallTime} · 3a: {data.thirdCallTime} hrs</span>
          </span>
          <span class="flex items-center gap-2 text-sm font-medium text-slate-400">
            <svg class="w-4 h-4 text-orange-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
            </svg>
            <span class="text-white/80">{data.location}</span>
          </span>
        </div>
      </div>

      <!-- Separador y botones -->
      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 pt-6 border-t border-white/10">
        {data.administrator && (
          <p class="text-[10px] font-black uppercase tracking-[0.4em] text-slate-600">
            Convoca la Administración
          </p>
        )}
        <div class="flex gap-3 sm:ml-auto">
          {data.pdfUrl && (
            <a
              href={data.pdfUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-5 py-3 rounded-xl border border-white/20 hover:border-white/40 text-white/70 hover:text-white font-black text-[11px] uppercase tracking-widest transition-all"
            >
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" />
              </svg>
              PDF
            </a>
          )}
          <button
            id={`btn-open-${modalId}`}
            class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl bg-white hover:bg-orange-50 text-slate-900 font-black text-[11px] uppercase tracking-widest transition-all shadow-lg shadow-black/20 hover:shadow-xl cursor-pointer"
            aria-controls={modalId}
            aria-expanded="false"
          >
            <svg class="w-3.5 h-3.5 text-orange-500" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
            </svg>
            Ver convocatoria
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Modal con texto completo -->
<dialog
  id={modalId}
  class="w-full max-w-3xl max-h-[90vh] rounded-[2rem] p-0 shadow-2xl backdrop:bg-slate-900/70 backdrop:backdrop-blur-sm open:flex open:flex-col"
  style="position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); margin: 0;"
  aria-labelledby={`${modalId}-title`}
  aria-modal="true"
>
  <!-- Header del modal -->
  <div class="flex items-center justify-between px-6 sm:px-8 py-5 border-b border-slate-100 shrink-0 bg-slate-900 rounded-t-[2rem]">
    <div>
      <span class="text-[9px] font-black uppercase tracking-[0.5em] text-orange-400 block mb-1">
        Convocatoria Oficial
      </span>
      <h3
        id={`${modalId}-title`}
        class="text-lg sm:text-xl font-black text-white tracking-tight leading-tight"
      >
        {data.title}
      </h3>
    </div>
    <button
      id={`btn-close-${modalId}`}
      class="w-10 h-10 rounded-xl bg-white/10 hover:bg-white/20 text-white/60 hover:text-white flex items-center justify-center transition-colors shrink-0 ml-4 cursor-pointer"
      aria-label="Cerrar"
    >
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Contenido scrollable -->
  <div class="overflow-y-auto p-6 sm:p-8 grow bg-white">
    <div class="prose prose-slate prose-sm sm:prose-base max-w-none
      prose-headings:font-black prose-headings:tracking-tight prose-headings:text-slate-900
      prose-h2:text-sm prose-h2:uppercase prose-h2:tracking-[0.2em] prose-h2:text-orange-600 prose-h2:border-b prose-h2:border-orange-100 prose-h2:pb-2 prose-h2:mt-8
      prose-h3:text-xs prose-h3:uppercase prose-h3:tracking-widest prose-h3:text-slate-500
      prose-strong:text-slate-900 prose-strong:font-black
      prose-p:text-slate-600 prose-p:leading-relaxed
      prose-ol:text-slate-600
      prose-hr:border-slate-100
      prose-a:text-orange-500 prose-a:no-underline hover:prose-a:underline
    ">
      <Content />
    </div>
  </div>

  <!-- Footer del modal -->
  <div class="px-6 sm:px-8 py-5 border-t border-slate-100 shrink-0 flex flex-col sm:flex-row gap-3 items-center justify-between bg-slate-50 rounded-b-[2rem]">
    <p class="text-[10px] font-black uppercase tracking-widest text-slate-400">
      {data.administrator && `Adm. ${data.administrator}`}
    </p>
    <div class="flex gap-2">
      {data.pdfUrl && (
        <a
          href={data.pdfUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-4 py-2.5 rounded-xl bg-white border border-slate-200 hover:border-orange-200 text-slate-600 hover:text-orange-600 font-black text-[10px] uppercase tracking-widest transition-all"
        >
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" />
          </svg>
          Descargar PDF
        </a>
      )}
      <button
        id={`btn-close2-${modalId}`}
        class="inline-flex items-center gap-2 px-4 py-2.5 rounded-xl bg-slate-900 hover:bg-slate-800 text-white font-black text-[10px] uppercase tracking-widest transition-colors cursor-pointer"
      >
        Cerrar
      </button>
    </div>
  </div>
</dialog>

<script define:vars={{ modalId }}>
  const modal = document.getElementById(modalId);
  const btnOpen = document.getElementById(`btn-open-${modalId}`);
  const btnClose = document.getElementById(`btn-close-${modalId}`);
  const btnClose2 = document.getElementById(`btn-close2-${modalId}`);

  function openModal() {
    modal.showModal();
    btnOpen.setAttribute("aria-expanded", "true");
    document.body.style.overflow = "hidden";
  }

  function closeModal() {
    modal.close();
    btnOpen.setAttribute("aria-expanded", "false");
    document.body.style.overflow = "";
  }

  btnOpen?.addEventListener("click", openModal);
  btnClose?.addEventListener("click", closeModal);
  btnClose2?.addEventListener("click", closeModal);

  modal?.addEventListener("click", (e) => {
    const rect = modal.getBoundingClientRect();
    const isInDialog =
      rect.top <= e.clientY &&
      e.clientY <= rect.top + rect.height &&
      rect.left <= e.clientX &&
      e.clientX <= rect.left + rect.width;
    if (!isInDialog) closeModal();
  });

  modal?.addEventListener("cancel", (e) => {
    e.preventDefault();
    closeModal();
  });
</script>
