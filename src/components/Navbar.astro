<header
  id="main-header"
  class="py-6 lg:py-10 bg-white/60 backdrop-blur-md sticky top-0 z-50 border-b border-orange-100/50 transition-colors duration-300 relative"
>
  <!-- Barra de progreso de scroll -->
  <div
    id="scroll-progress"
    class="absolute bottom-0 left-0 h-[2px] bg-orange-500 w-0 transition-none origin-left"
    style="will-change: width;"
  ></div>
  <div class="container mx-auto px-4 flex justify-between items-center">
    <a href="/" class="group flex items-center gap-3 relative z-50">
      <div
        class="w-10 h-10 rounded-xl bg-gradient-to-br from-orange-400 to-violet-500 shadow-lg shadow-orange-200 flex items-center justify-center text-white font-black italic text-xl group-hover:scale-110 transition-transform"
      >
        O
      </div>
      <div class="flex flex-col">
        <span
          class="text-xl font-black tracking-tight text-slate-900 leading-none"
          >Ocaso 43</span
        >
        <span
          class="text-[10px] uppercase tracking-[0.3em] font-bold text-orange-500"
          >Administración</span
        >
      </div>
    </a>

    <!-- Botón Menú Móvil -->
    <button
      id="menu-toggle"
      class="lg:hidden relative z-50 w-10 h-10 flex flex-col items-center justify-center gap-1.5 focus:outline-none"
      aria-label="Abrir menú"
    >
      <span class="w-6 h-0.5 bg-slate-900 transition-all origin-center"></span>
      <span class="w-6 h-0.5 bg-slate-900 transition-all"></span>
      <span class="w-6 h-0.5 bg-slate-900 transition-all origin-center"></span>
    </button>

    <!-- Navegación Escritorio -->
    <nav class="hidden lg:block">
      <ul
        class="flex gap-8 text-sm font-bold uppercase tracking-widest text-slate-700"
      >
        <li>
          <a href="/" class="hover:text-orange-500 transition-colors">Inicio</a>
        </li>
        <li>
          <a href="/minutas" class="hover:text-orange-500 transition-colors"
            >Minutas</a
          >
        </li>
        <li>
          <a href="/documentos" class="hover:text-orange-500 transition-colors"
            >Documentos</a
          >
        </li>
        <li>
          <a href="/trabajos" class="hover:text-pink-500 transition-colors"
            >Trabajos</a
          >
        </li>
        <li>
          <a href="/solicitudes" class="hover:text-orange-500 transition-colors">Solicitudes</a>
        </li>
        <li>
          <a href={Astro.locals.comisionUser ? "/comision-vigilancia" : "/comision-vigilancia/login"} class="hover:text-violet-500 transition-colors flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Comisión
          </a>
        </li>
      </ul>
    </nav>

  </div>
</header>

<!-- Menú Móvil Overlay (fixed, fuera del header) -->
<div
  id="mobile-menu"
  class="fixed inset-0 bg-white/95 backdrop-blur-3xl z-[100] flex flex-col items-center justify-center lg:hidden opacity-0 pointer-events-none translate-y-[-20px]"
>
  <!-- Decoración de fondo -->
  <div
    class="absolute inset-0 bg-gradient-to-b from-orange-50/50 via-white to-violet-50/50 -z-10"
  ></div>

  <!-- Botón cerrar dentro del overlay -->
  <button
    id="menu-close"
    class="fixed top-6 right-4 z-10 w-10 h-10 flex flex-col items-center justify-center gap-1.5 focus:outline-none"
    aria-label="Cerrar menú"
  >
    <span class="w-6 h-0.5 bg-slate-900 origin-center" style="transform: rotate(45deg) translate(3px, 3px)"></span>
    <span class="w-6 h-0.5 bg-slate-900 origin-center" style="transform: rotate(-45deg) translate(2px, -3px)"></span>
  </button>

  <nav class="relative z-10 w-full px-8 flex flex-col items-center">
    <ul class="flex flex-col gap-8 text-center">
      <li>
        <a href="/" class="mobile-nav-link group flex flex-col items-center">
          <span class="text-xs font-black uppercase tracking-[0.4em] text-orange-400 opacity-0 group-hover:opacity-100 transition-opacity mb-2">01</span>
          <span class="text-4xl font-black text-slate-900 tracking-tighter group-hover:text-orange-500 transition-all">Inicio</span>
        </a>
      </li>
      <li>
        <a href="/minutas" class="mobile-nav-link group flex flex-col items-center">
          <span class="text-xs font-black uppercase tracking-[0.4em] text-orange-400 opacity-0 group-hover:opacity-100 transition-opacity mb-2">02</span>
          <span class="text-4xl font-black text-slate-900 tracking-tighter group-hover:text-orange-500 transition-all">Minutas</span>
        </a>
      </li>
      <li>
        <a href="/documentos" class="mobile-nav-link group flex flex-col items-center">
          <span class="text-xs font-black uppercase tracking-[0.4em] text-orange-400 opacity-0 group-hover:opacity-100 transition-opacity mb-2">03</span>
          <span class="text-4xl font-black text-slate-900 tracking-tighter group-hover:text-orange-500 transition-all">Documentos</span>
        </a>
      </li>
      <li>
        <a href="/trabajos" class="mobile-nav-link group flex flex-col items-center">
          <span class="text-xs font-black uppercase tracking-[0.4em] text-pink-400 opacity-0 group-hover:opacity-100 transition-opacity mb-2">04</span>
          <span class="text-4xl font-black text-slate-900 tracking-tighter group-hover:text-pink-500 transition-all">Trabajos</span>
        </a>
      </li>
      <li>
        <a href="/solicitudes" class="mobile-nav-link group flex flex-col items-center">
          <span class="text-xs font-black uppercase tracking-[0.4em] text-orange-400 opacity-0 group-hover:opacity-100 transition-opacity mb-2">05</span>
          <span class="text-4xl font-black text-slate-900 tracking-tighter group-hover:text-orange-500 transition-all">Solicitudes</span>
        </a>
      </li>
      <li>
        <a href={Astro.locals.comisionUser ? "/comision-vigilancia" : "/comision-vigilancia/login"} class="mobile-nav-link group flex flex-col items-center">
          <span class="text-xs font-black uppercase tracking-[0.4em] text-violet-400 opacity-0 group-hover:opacity-100 transition-opacity mb-2">06</span>
          <span class="text-4xl font-black text-slate-900 tracking-tighter group-hover:text-violet-500 transition-all">Comisión</span>
        </a>
      </li>
    </ul>

    <div class="mt-20 flex flex-col items-center gap-4">
      <div class="w-10 h-px bg-slate-200"></div>
      <p class="text-[10px] font-black uppercase tracking-[0.4em] text-slate-400">Ocaso 43</p>
    </div>
  </nav>
</div>

<script>
  const menuToggle = document.getElementById("menu-toggle");
  const menuClose = document.getElementById("menu-close");
  const mobileMenu = document.getElementById("mobile-menu");
  const body = document.body;

  menuToggle?.addEventListener("click", openMenu);
  menuClose?.addEventListener("click", closeMenu);

  // Cerrar con fade y luego navegar
  const links = document.querySelectorAll(".mobile-nav-link");
  links.forEach((link) => {
    link.addEventListener("click", (e) => {
      e.preventDefault();
      const href = (link as HTMLAnchorElement).href;
      closeMenu();
      setTimeout(() => {
        window.location.href = href;
      }, 300);
    });
  });

  function openMenu() {
    mobileMenu?.classList.add("transition-all", "duration-500", "ease-in-out");
    mobileMenu?.classList.remove(
      "opacity-0",
      "pointer-events-none",
      "translate-y-[-20px]",
    );
    mobileMenu?.classList.add("opacity-100", "translate-y-0");
    document.documentElement.style.overflow = "hidden";
    body.style.overflow = "hidden";
  }

  function closeMenu() {
    mobileMenu?.classList.add(
      "opacity-0",
      "pointer-events-none",
      "translate-y-[-10px]",
    );
    mobileMenu?.classList.remove("opacity-100", "translate-y-0");
    document.documentElement.style.overflow = "";
    body.style.overflow = "";
  }

  // Opacidad del header al hacer scroll
  const header = document.getElementById("main-header");
  function updateHeaderOpacity() {
    if (!header) return;
    if (window.scrollY > 10) {
      header.classList.add("bg-white/90");
      header.classList.remove("bg-white/60");
    } else {
      header.classList.add("bg-white/60");
      header.classList.remove("bg-white/90");
    }
  }
  window.addEventListener("scroll", updateHeaderOpacity, { passive: true });
  updateHeaderOpacity();

  // Barra de progreso de scroll
  const scrollBar = document.getElementById("scroll-progress");
  function updateScrollProgress() {
    if (!scrollBar) return;
    const scrollTop = window.scrollY;
    const docHeight = document.documentElement.scrollHeight - window.innerHeight;
    if (docHeight <= 0) {
      scrollBar.style.width = "0%";
      return;
    }
    const pct = Math.min(100, (scrollTop / docHeight) * 100);
    scrollBar.style.width = pct + "%";
  }
  window.addEventListener("scroll", updateScrollProgress, { passive: true });
  updateScrollProgress();
</script>
