---
/**
 * TrabajoGallery - Before/During/After image gallery component
 * Interactive tabs to switch between stages
 */

interface ImageData {
  url: string;
  tipo: 'antes' | 'durante' | 'despues';
  descripcion?: string;
}

interface Props {
  imagenes: ImageData[];
}

const { imagenes } = Astro.props;

// Group images by tipo
const imagesByTipo = {
  antes: imagenes.filter((img) => img.tipo === 'antes'),
  durante: imagenes.filter((img) => img.tipo === 'durante'),
  despues: imagenes.filter((img) => img.tipo === 'despues'),
};

const hasBefore = imagesByTipo.antes.length > 0;
const hasDuring = imagesByTipo.durante.length > 0;
const hasAfter = imagesByTipo.despues.length > 0;

// Determine default tab (priority: despues > durante > antes)
const defaultTab = hasAfter ? 'despues' : (hasDuring ? 'durante' : 'antes');

const tipoLabels = {
  antes: 'Antes',
  durante: 'Durante',
  despues: 'Después',
};
---

{
  imagenes.length > 0 && (
    <div class="rounded-3xl bg-white border border-slate-100 overflow-hidden">
      <div class="p-6 border-b border-slate-100">
        <h3 class="text-2xl font-black text-slate-900">Galería del Trabajo</h3>
        <p class="text-sm text-slate-500 font-medium mt-1">
          Documentación visual del proceso
        </p>
      </div>

      {/* Tab Navigation */}
      <div class="flex border-b border-slate-100 px-6 gap-2">
        {hasBefore && (
          <button
            data-tab="antes"
            class="tab-button px-6 py-4 text-sm font-black uppercase tracking-widest border-b-2 border-transparent transition-all hover:text-orange-500 hover:border-orange-200 data-[active=true]:text-orange-500 data-[active=true]:border-orange-500"
            data-active={defaultTab === 'antes' ? 'true' : 'false'}
          >
            {tipoLabels.antes}
          </button>
        )}
        {hasDuring && (
          <button
            data-tab="durante"
            class="tab-button px-6 py-4 text-sm font-black uppercase tracking-widest border-b-2 border-transparent transition-all hover:text-orange-500 hover:border-orange-200 data-[active=true]:text-orange-500 data-[active=true]:border-orange-500"
            data-active={defaultTab === 'durante' ? 'true' : 'false'}
          >
            {tipoLabels.durante}
          </button>
        )}
        {hasAfter && (
          <button
            data-tab="despues"
            class="tab-button px-6 py-4 text-sm font-black uppercase tracking-widest border-b-2 border-transparent transition-all hover:text-orange-500 hover:border-orange-200 data-[active=true]:text-orange-500 data-[active=true]:border-orange-500"
            data-active={defaultTab === 'despues' ? 'true' : 'false'}
          >
            {tipoLabels.despues}
          </button>
        )}
      </div>

      {/* Tab Content */}
      <div class="p-6">
        {hasBefore && (
          <div
            data-content="antes"
            class={defaultTab === 'antes' ? 'tab-content' : 'tab-content hidden'}
            data-active={defaultTab === 'antes' ? 'true' : 'false'}
          >
            <div class="grid sm:grid-cols-2 gap-4">
              {imagesByTipo.antes.map((img, index) => (
                <div class="rounded-2xl overflow-hidden bg-slate-50 group">
                  <div class="relative overflow-hidden cursor-pointer" data-lightbox-trigger data-img-url={img.url} data-img-alt={img.descripcion || 'Antes del trabajo'}>
                    <img
                      src={img.url}
                      alt={img.descripcion || 'Antes del trabajo'}
                      class="w-full h-auto transition-transform duration-300 group-hover:scale-105"
                      loading="lazy"
                    />
                    <div class="absolute inset-0 bg-black opacity-0 group-hover:opacity-10 transition-opacity duration-300"></div>
                    <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                      <span class="text-white text-4xl font-bold drop-shadow-lg">🔍</span>
                    </div>
                  </div>
                  {img.descripcion && (
                    <p class="p-4 text-sm text-slate-600 font-medium italic">
                      {img.descripcion}
                    </p>
                  )}
                </div>
              ))}
            </div>
          </div>
        )}

        {hasDuring && (
          <div
            data-content="durante"
            class={defaultTab === 'durante' ? 'tab-content' : 'tab-content hidden'}
            data-active={defaultTab === 'durante' ? 'true' : 'false'}
          >
            <div class="grid sm:grid-cols-2 gap-4">
              {imagesByTipo.durante.map((img, index) => (
                <div class="rounded-2xl overflow-hidden bg-slate-50 group">
                  <div class="relative overflow-hidden cursor-pointer" data-lightbox-trigger data-img-url={img.url} data-img-alt={img.descripcion || 'Durante el trabajo'}>
                    <img
                      src={img.url}
                      alt={img.descripcion || 'Durante el trabajo'}
                      class="w-full h-auto transition-transform duration-300 group-hover:scale-105"
                      loading="lazy"
                    />
                    <div class="absolute inset-0 bg-black opacity-0 group-hover:opacity-10 transition-opacity duration-300"></div>
                    <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                      <span class="text-white text-4xl font-bold drop-shadow-lg">🔍</span>
                    </div>
                  </div>
                  {img.descripcion && (
                    <p class="p-4 text-sm text-slate-600 font-medium italic">
                      {img.descripcion}
                    </p>
                  )}
                </div>
              ))}
            </div>
          </div>
        )}

        {hasAfter && (
          <div
            data-content="despues"
            class={defaultTab === 'despues' ? 'tab-content' : 'tab-content hidden'}
            data-active={defaultTab === 'despues' ? 'true' : 'false'}
          >
            <div class="grid sm:grid-cols-2 gap-4">
              {imagesByTipo.despues.map((img, index) => (
                <div class="rounded-2xl overflow-hidden bg-slate-50 group">
                  <div class="relative overflow-hidden cursor-pointer" data-lightbox-trigger data-img-url={img.url} data-img-alt={img.descripcion || 'Después del trabajo'}>
                    <img
                      src={img.url}
                      alt={img.descripcion || 'Después del trabajo'}
                      class="w-full h-auto transition-transform duration-300 group-hover:scale-105"
                      loading="lazy"
                    />
                    <div class="absolute inset-0 bg-black opacity-0 group-hover:opacity-10 transition-opacity duration-300"></div>
                    <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                      <span class="text-white text-4xl font-bold drop-shadow-lg">🔍</span>
                    </div>
                  </div>
                  {img.descripcion && (
                    <p class="p-4 text-sm text-slate-600 font-medium italic">
                      {img.descripcion}
                    </p>
                  )}
                </div>
              ))}
            </div>
          </div>
        )}
      </div>
    </div>
  )
}

{/* Lightbox Modal */}
<div id="lightbox-modal" class="fixed inset-0 bg-black/90 z-50 hidden items-center justify-center p-4 backdrop-blur-sm cursor-pointer">
  <button 
    id="lightbox-close" 
    class="absolute top-6 right-6 text-white text-4xl font-bold hover:text-orange-500 transition-colors z-10 cursor-pointer"
    aria-label="Cerrar"
  >
    ×
  </button>
  <div class="relative max-w-7xl max-h-[90vh] w-full h-full flex items-center justify-center pointer-events-none">
    <img 
      id="lightbox-img" 
      src="" 
      alt="" 
      class="max-w-full max-h-full w-auto h-auto object-contain rounded-2xl shadow-2xl"
    />
  </div>
  <p id="lightbox-caption" class="absolute bottom-6 left-1/2 -translate-x-1/2 text-white text-center text-sm font-medium px-6 py-3 bg-black/50 rounded-full max-w-2xl pointer-events-none"></p>
</div>

<script>
  // Tab switching logic
  document.addEventListener('DOMContentLoaded', () => {
    const tabButtons = document.querySelectorAll('.tab-button');
    const tabContents = document.querySelectorAll('.tab-content');

    tabButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const targetTab = button.getAttribute('data-tab');

        // Update buttons
        tabButtons.forEach((btn) => {
          btn.setAttribute('data-active', 'false');
        });
        button.setAttribute('data-active', 'true');

        // Update content
        tabContents.forEach((content) => {
          const contentType = content.getAttribute('data-content');
          if (contentType === targetTab) {
            content.classList.remove('hidden');
            content.setAttribute('data-active', 'true');
          } else {
            content.classList.add('hidden');
            content.setAttribute('data-active', 'false');
          }
        });
      });
    });

    // Lightbox functionality
    const lightboxModal = document.getElementById('lightbox-modal');
    const lightboxImg = document.getElementById('lightbox-img');
    const lightboxCaption = document.getElementById('lightbox-caption');
    const lightboxClose = document.getElementById('lightbox-close');
    const triggers = document.querySelectorAll('[data-lightbox-trigger]');

    triggers.forEach((trigger) => {
      trigger.addEventListener('click', () => {
        const imgUrl = trigger.getAttribute('data-img-url');
        const imgAlt = trigger.getAttribute('data-img-alt');
        
        if (lightboxImg && lightboxCaption && lightboxModal) {
          lightboxImg.src = imgUrl || '';
          lightboxImg.alt = imgAlt || '';
          lightboxCaption.textContent = imgAlt || '';
          lightboxModal.classList.remove('hidden');
          lightboxModal.classList.add('flex');
          document.body.style.overflow = 'hidden'; // Prevent scrolling
        }
      });
    });

    // Close lightbox
    const closeLightbox = () => {
      if (lightboxModal) {
        lightboxModal.classList.add('hidden');
        lightboxModal.classList.remove('flex');
        document.body.style.overflow = ''; // Restore scrolling
      }
    };

    // Close on X button click
    if (lightboxClose) {
      lightboxClose.addEventListener('click', (e) => {
        e.stopPropagation(); // Prevent modal click handler
        closeLightbox();
      });
    }

    // Close on any click on the modal (background or anywhere)
    if (lightboxModal) {
      lightboxModal.addEventListener('click', () => {
        closeLightbox();
      });
    }

    // Close on Escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        closeLightbox();
      }
    });
  });
</script>
