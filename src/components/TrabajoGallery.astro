---
/**
 * TrabajoGallery - Before/During/After image gallery component
 * Interactive tabs to switch between stages
 */

interface ImageData {
  url: string;
  tipo: 'antes' | 'durante' | 'despues';
  descripcion?: string;
}

interface Props {
  imagenes: ImageData[];
}

const { imagenes } = Astro.props;

// Group images by tipo
const imagesByTipo = {
  antes: imagenes.filter((img) => img.tipo === 'antes'),
  durante: imagenes.filter((img) => img.tipo === 'durante'),
  despues: imagenes.filter((img) => img.tipo === 'despues'),
};

const hasBefore = imagesByTipo.antes.length > 0;
const hasDuring = imagesByTipo.durante.length > 0;
const hasAfter = imagesByTipo.despues.length > 0;

// Determine default tab (priority: despues > durante > antes)
const defaultTab = hasAfter ? 'despues' : (hasDuring ? 'durante' : 'antes');

const tipoLabels = {
  antes: 'Antes',
  durante: 'Durante',
  despues: 'Después',
};
---

{
  imagenes.length > 0 && (
    <div class="rounded-3xl bg-white border border-slate-100 overflow-hidden">
      <div class="p-6 border-b border-slate-100">
        <h3 class="text-2xl font-black text-slate-900">Galería del Trabajo</h3>
        <p class="text-sm text-slate-500 font-medium mt-1">
          Documentación visual del proceso
        </p>
      </div>

      <!-- Tab Navigation -->
      <div class="flex border-b border-slate-100 px-6 gap-2" role="tablist" aria-label="Etapas del trabajo">
        {hasBefore && (
          <button
            data-tab="antes"
            role="tab"
            aria-selected={defaultTab === 'antes' ? 'true' : 'false'}
            aria-controls="panel-antes"
            class="tab-button px-6 py-4 text-sm font-black uppercase tracking-widest border-b-2 border-transparent hover:text-orange-500 hover:border-orange-200 data-[active=true]:text-orange-500 data-[active=true]:border-orange-500 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:ring-offset-2 transition-[color,border-color] duration-200 ease-out"
            data-active={defaultTab === 'antes' ? 'true' : 'false'}
          >
            {tipoLabels.antes}
          </button>
        )}
        {hasDuring && (
          <button
            data-tab="durante"
            role="tab"
            aria-selected={defaultTab === 'durante' ? 'true' : 'false'}
            aria-controls="panel-durante"
            class="tab-button px-6 py-4 text-sm font-black uppercase tracking-widest border-b-2 border-transparent hover:text-orange-500 hover:border-orange-200 data-[active=true]:text-orange-500 data-[active=true]:border-orange-500 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:ring-offset-2 transition-[color,border-color] duration-200 ease-out"
            data-active={defaultTab === 'durante' ? 'true' : 'false'}
          >
            {tipoLabels.durante}
          </button>
        )}
        {hasAfter && (
          <button
            data-tab="despues"
            role="tab"
            aria-selected={defaultTab === 'despues' ? 'true' : 'false'}
            aria-controls="panel-despues"
            class="tab-button px-6 py-4 text-sm font-black uppercase tracking-widest border-b-2 border-transparent hover:text-orange-500 hover:border-orange-200 data-[active=true]:text-orange-500 data-[active=true]:border-orange-500 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:ring-offset-2 transition-[color,border-color] duration-200 ease-out"
            data-active={defaultTab === 'despues' ? 'true' : 'false'}
          >
            {tipoLabels.despues}
          </button>
        )}
      </div>

      <!-- Tab Content -->
      <div class="p-6">
        {hasBefore && (
          <div
            id="panel-antes"
            data-content="antes"
            role="tabpanel"
            aria-labelledby="tab-antes"
            class={defaultTab === 'antes' ? 'tab-content' : 'tab-content hidden'}
            data-active={defaultTab === 'antes' ? 'true' : 'false'}
          >
            <div class="grid sm:grid-cols-2 gap-4">
              {imagesByTipo.antes.map((img, index) => (
                <div class="rounded-2xl overflow-hidden bg-slate-50 group">
                  <button 
                    type="button"
                    class="relative overflow-hidden cursor-pointer w-full text-left focus:outline-none focus:ring-2 focus:ring-orange-500 focus:ring-offset-2" 
                    data-lightbox-trigger 
                    data-img-url={img.url} 
                    data-img-alt={img.descripcion || 'Antes del trabajo'}
                    aria-label={`Ver imagen ampliada: ${img.descripcion || 'Antes del trabajo'}`}
                  >
                    <img
                      src={img.url}
                      alt={img.descripcion || 'Antes del trabajo'}
                      class="w-full h-auto transition-transform duration-300 ease-out group-hover:scale-105"
                      loading="lazy"
                    />
                    <div class="absolute inset-0 bg-black opacity-0 group-hover:opacity-10 transition-opacity duration-200 ease-out"></div>
                    <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-200 ease-out">
                      <span class="text-white text-4xl font-bold drop-shadow-lg">🔍</span>
                    </div>
                  </button>
                  {img.descripcion && (
                    <p class="p-4 text-sm text-slate-600 font-medium italic leading-relaxed">
                      {img.descripcion}
                    </p>
                  )}
                </div>
              ))}
            </div>
          </div>
        )}

        {hasDuring && (
          <div
            id="panel-durante"
            data-content="durante"
            role="tabpanel"
            aria-labelledby="tab-durante"
            class={defaultTab === 'durante' ? 'tab-content' : 'tab-content hidden'}
            data-active={defaultTab === 'durante' ? 'true' : 'false'}
          >
            <div class="grid sm:grid-cols-2 gap-4">
              {imagesByTipo.durante.map((img, index) => (
                <div class="rounded-2xl overflow-hidden bg-slate-50 group">
                  <button 
                    type="button"
                    class="relative overflow-hidden cursor-pointer w-full text-left focus:outline-none focus:ring-2 focus:ring-orange-500 focus:ring-offset-2" 
                    data-lightbox-trigger 
                    data-img-url={img.url} 
                    data-img-alt={img.descripcion || 'Durante el trabajo'}
                    aria-label={`Ver imagen ampliada: ${img.descripcion || 'Durante el trabajo'}`}
                  >
                    <img
                      src={img.url}
                      alt={img.descripcion || 'Durante el trabajo'}
                      class="w-full h-auto transition-transform duration-300 ease-out group-hover:scale-105"
                      loading="lazy"
                    />
                    <div class="absolute inset-0 bg-black opacity-0 group-hover:opacity-10 transition-opacity duration-200 ease-out"></div>
                    <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-200 ease-out">
                      <span class="text-white text-4xl font-bold drop-shadow-lg">🔍</span>
                    </div>
                  </button>
                  {img.descripcion && (
                    <p class="p-4 text-sm text-slate-600 font-medium italic leading-relaxed">
                      {img.descripcion}
                    </p>
                  )}
                </div>
              ))}
            </div>
          </div>
        )}

        {hasAfter && (
          <div
            id="panel-despues"
            data-content="despues"
            role="tabpanel"
            aria-labelledby="tab-despues"
            class={defaultTab === 'despues' ? 'tab-content' : 'tab-content hidden'}
            data-active={defaultTab === 'despues' ? 'true' : 'false'}
          >
            <div class="grid sm:grid-cols-2 gap-4">
              {imagesByTipo.despues.map((img, index) => (
                <div class="rounded-2xl overflow-hidden bg-slate-50 group">
                  <button 
                    type="button"
                    class="relative overflow-hidden cursor-pointer w-full text-left focus:outline-none focus:ring-2 focus:ring-orange-500 focus:ring-offset-2" 
                    data-lightbox-trigger 
                    data-img-url={img.url} 
                    data-img-alt={img.descripcion || 'Después del trabajo'}
                    aria-label={`Ver imagen ampliada: ${img.descripcion || 'Después del trabajo'}`}
                  >
                    <img
                      src={img.url}
                      alt={img.descripcion || 'Después del trabajo'}
                      class="w-full h-auto transition-transform duration-300 ease-out group-hover:scale-105"
                      loading="lazy"
                    />
                    <div class="absolute inset-0 bg-black opacity-0 group-hover:opacity-10 transition-opacity duration-200 ease-out"></div>
                    <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-200 ease-out">
                      <span class="text-white text-4xl font-bold drop-shadow-lg">🔍</span>
                    </div>
                  </button>
                  {img.descripcion && (
                    <p class="p-4 text-sm text-slate-600 font-medium italic leading-relaxed">
                      {img.descripcion}
                    </p>
                  )}
                </div>
              ))}
            </div>
          </div>
        )}
      </div>
    </div>
  )
}

<script>
  // Tab switching logic
  document.addEventListener('DOMContentLoaded', () => {
    const tabButtons = document.querySelectorAll('.tab-button');
    const tabContents = document.querySelectorAll('.tab-content');

    tabButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const targetTab = button.getAttribute('data-tab');

        // Update buttons and ARIA attributes
        tabButtons.forEach((btn) => {
          btn.setAttribute('data-active', 'false');
          btn.setAttribute('aria-selected', 'false');
        });
        button.setAttribute('data-active', 'true');
        button.setAttribute('aria-selected', 'true');

        // Update content
        tabContents.forEach((content) => {
          const contentType = content.getAttribute('data-content');
          if (contentType === targetTab) {
            content.classList.remove('hidden');
            content.setAttribute('data-active', 'true');
          } else {
            content.classList.add('hidden');
            content.setAttribute('data-active', 'false');
          }
        });
      });

      // Keyboard navigation for tabs
      button.addEventListener('keydown', (e) => {
        const evt = e as KeyboardEvent;
        if (evt.key === 'ArrowRight' || evt.key === 'ArrowLeft') {
          evt.preventDefault();
          const buttons = Array.from(tabButtons);
          const currentIndex = buttons.indexOf(button);
          const nextIndex = evt.key === 'ArrowRight'
            ? (currentIndex + 1) % buttons.length
            : (currentIndex - 1 + buttons.length) % buttons.length;
          (buttons[nextIndex] as HTMLElement).focus();
          (buttons[nextIndex] as HTMLElement).click();
        }
      });
    });
  });
</script>
